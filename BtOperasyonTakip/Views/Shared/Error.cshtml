@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<h1 class="text-danger">Hata.</h1>
<h2 class="text-danger">İsteğiniz işlenirken bir hata oluştu.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>İstek ID:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Geliştirme Modu</h3>
<p>
    <strong>Development</strong> ortamına geçmek, oluşan hata hakkında daha ayrıntılı bilgi gösterir.
</p>
<p>
    <strong>Development ortamı yayındaki uygulamalarda etkinleştirilmemelidir.</strong>
    Bu durum istisnalardaki hassas bilgilerin son kullanıcılara gösterilmesine neden olabilir.
    Yerel hata ayıklama için <strong>ASPNETCORE_ENVIRONMENT</strong> ortam değişkenini <strong>Development</strong> yapıp uygulamayı yeniden başlatın.
</p>

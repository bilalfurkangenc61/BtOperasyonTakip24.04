@using System.Reflection
@{
    var appVersion = Assembly.GetEntryAssembly()?
        .GetCustomAttribute<AssemblyInformationalVersionAttribute>()?
        .InformationalVersion?
        .Split('+')[0]
        ?? Assembly.GetEntryAssembly()?.GetName().Version?.ToString()
        ?? "1.0.0";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] -Operasyon Takip</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        html, body {
            height: 100%;
            display: flex;
            flex-direction: column;
            background: linear-gradient(180deg, #f6f9ff, #eaf1ff);
            font-family: 'Segoe UI', Roboto, Arial, sans-serif;
            margin: 0;
        }

        main {
            flex: 1;
        }

        .navbar {
            background: rgba(15, 23, 42, 0.92);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            box-shadow: 0 10px 28px rgba(15, 23, 42, 0.18);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            padding-top: 0.8rem;
            padding-bottom: 0.8rem;
        }

        .navbar-brand {
            font-weight: 700;
            letter-spacing: 0.3px;
            display: inline-flex;
            align-items: center;
            gap: 0.65rem;
            padding: 0.55rem 0.9rem;
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.08);
        }

        .nav-link {
            font-weight: 600;
            transition: 0.3s ease;
            border-radius: 12px;
            padding: 0.65rem 0.9rem !important;
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            color: rgba(255, 255, 255, 0.86) !important;
        }

            .nav-link:hover,
            .nav-link.active {
                color: #fff !important;
                background: rgba(255, 255, 255, 0.12);
                box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
            }

        .navbar-nav {
            gap: 0.35rem;
        }

        .navbar-nav .nav-item {
            display: flex;
        }

        .navbar-text small {
            color: #cdd9ff;
        }

        .card {
            border-radius: 1rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }

        table.dataTable thead {
            background-color: #e8f0ff;
            color: #003366;
            font-weight: 600;
        }

        footer.footer {
            background: rgba(255, 255, 255, 0.88);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            font-size: 0.9rem;
            box-shadow: 0 -8px 24px rgba(15, 23, 42, 0.06);
            position: sticky;
            bottom: 0;
            width: 100%;
            z-index: 10;
            border-top: 1px solid rgba(15, 23, 42, 0.06);
        }

        .footer-inner {
            min-height: 64px;
        }

        .footer-brand {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: #0f172a;
            font-weight: 600;
        }

        .footer-version {
            display: inline-flex;
            align-items: center;
            padding: 0.4rem 0.75rem;
            border-radius: 999px;
            background: linear-gradient(90deg, #eef4ff, #f5f3ff);
            color: #1d4ed8;
            border: 1px solid #dbe7ff;
            font-weight: 700;
            font-size: 0.82rem;
        }

        @@media (max-width: 767.98px) {
            .footer-inner {
                flex-direction: column;
                gap: 0.5rem;
                text-align: center;
            }
        }

        .nav-profile {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 14px;
            padding: 0.65rem 0.9rem;
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .dropdown-menu {
            border-radius: 14px;
            border: 1px solid rgba(15, 23, 42, 0.08);
            box-shadow: 0 12px 28px rgba(15, 23, 42, 0.12);
        }

        .page-title {
            color: #0056d6;
            font-weight: 600;
            margin-bottom: 1rem;
        }

        .nav-icon {
            opacity: 0.95;
        }

        @@media (max-width: 991.98px) {
            .navbar-collapse {
                margin-top: 1rem;
                padding-top: 1rem;
                border-top: 1px solid rgba(255, 255, 255, 0.08);
            }

            .navbar-nav {
                gap: 0.2rem;
            }

            .nav-profile {
                margin-top: 0.8rem;
                justify-content: center;
            }
        }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            @{
                var brandController = "Auth";
                var brandAction = "Login";
                if (User?.Identity?.IsAuthenticated == true)
                {
                    if (User.IsInRole("Operasyon") || User.IsInRole("Admin"))
                    {
                        brandController = "Dashboard";
                        brandAction = "Index";
                    }
                    else if (User.IsInRole("Saha"))
                    {
                        brandController = "Ticket";
                        brandAction = "Index";
                    }
                    else if (User.IsInRole("Uyum"))
                    {
                        brandController = "Uyum";
                        brandAction = "Index";
                    }
                }
            }
            <a class="navbar-brand text-white" asp-controller="@brandController" asp-action="@brandAction">
                <span class="fs-5">⚙️</span>
                <span>Operasyon Takip</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    @if (User?.Identity?.IsAuthenticated != true)
                    {
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Auth" asp-action="Login"><span class="nav-icon">🔐</span><span>Giriş</span></a></li>
                    }
                    else if (User.IsInRole("Operasyon") )
                    {
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index"><span class="nav-icon">🏠</span><span>Ana Sayfa</span></a></li>
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Musteri" ? "active" : "")" asp-controller="Musteri" asp-action="Index"><span class="nav-icon">📋</span><span>Müşteriler</span></a></li>
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Detay" ? "active" : "")" asp-controller="Detay" asp-action="Index"><span class="nav-icon">🗂️</span><span>Detaylar</span></a></li>
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ExcelAktarim" ? "active" : "")" asp-controller="ExcelAktarim" asp-action="Index"><span class="nav-icon">📥</span><span>Excel Aktarım</span></a></li>
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ToplantiNotlari" ? "active" : "")" asp-controller="ToplantiNotlari" asp-action="Index"><span class="nav-icon">🗒️</span><span>Toplantı Notları</span></a></li>

                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Takip" ? "active" : "")" asp-controller="Takip" asp-action="Index"><span class="nav-icon">🧾</span><span>İş Takip</span></a></li>
                       

                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Hatalar" ? "active" : "")" asp-controller="Hatalar" asp-action="Index"><span class="nav-icon">🚨</span><span>Hatalar</span></a></li>
                        
                    }else if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index"><span class="nav-icon">🏠</span><span>Ana Sayfa</span></a></li>
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Musteri" ? "active" : "")" asp-controller="Musteri" asp-action="Index"><span class="nav-icon">📋</span><span>Müşteriler</span></a></li>
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Detay" ? "active" : "")" asp-controller="Detay" asp-action="Index"><span class="nav-icon">🗂️</span><span>Detaylar</span></a></li>
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ExcelAktarim" ? "active" : "")" asp-controller="ExcelAktarim" asp-action="Index"><span class="nav-icon">📥</span><span>Excel Aktarım</span></a></li>
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ToplantiNotlari" ? "active" : "")" asp-controller="ToplantiNotlari" asp-action="Index"><span class="nav-icon">🗒️</span><span>Toplantı Notları</span></a></li>

                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Takip" ? "active" : "")" asp-controller="Takip" asp-action="Index"><span class="nav-icon">🧾</span><span>İş Takip</span></a></li>
                            
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Hatalar" ? "active" : "")" asp-controller="Hatalar" asp-action="Index"><span class="nav-icon">🚨</span><span>Hatalar</span></a></li>
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Izin" ? "active" : "")" asp-controller="Izin" asp-action="Index"><span class="nav-icon">🏖️</span><span>İzin Takip</span></a></li>
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Ticket" ? "active" : "")" asp-controller="Ticket" asp-action="Index"><span class="nav-icon">🎫</span><span>Ticketlar</span></a></li>
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Parametre" ? "active" : "")" asp-controller="Parametre" asp-action="Index"><span class="nav-icon">⚙️</span><span>Parametreler</span></a></li>
                            <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Auth" && ViewContext.RouteData.Values["page"]?.ToString() == "UserList" ? "active" : "")" asp-page="/Admin/UserList"><span class="nav-icon">👥</span><span>Kullanıcı Listesi</span></a></li>
                        }
                    else if (User.IsInRole("Saha"))
                    {
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Ticket" ? "active" : "")" asp-controller="Ticket" asp-action="Index"><span class="nav-icon">🎫</span><span>Ticketlar</span></a></li>
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Hatalar" ? "active" : "")" asp-controller="Hatalar" asp-action="Index"><span class="nav-icon">🚨</span><span>Hatalar</span></a></li>
                    }
                    else if (User.IsInRole("Uyum"))
                    {
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Uyum" ? "active" : "")" asp-controller="Uyum" asp-action="Index"><span class="nav-icon">🛡️</span><span>Uyum</span></a></li>
                    }
                    
                    else if (User.IsInRole("Saha") || User.IsInRole("KurumsalSaha"))
                    {
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Ticket" ? "active" : "")" asp-controller="Ticket" asp-action="Index"><span class="nav-icon">🎫</span><span>Ticketlar</span></a></li>
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Hatalar" ? "active" : "")" asp-controller="Hatalar" asp-action="Index"><span class="nav-icon">🚨</span><span>Hatalar</span></a></li>
                    }
                </ul>

                <div class="dropdown">
                    <a class="nav-profile d-flex align-items-center text-decoration-none dropdown-toggle" href="#" id="profileDropdown" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-2"></i>
                        <span>@(User?.Identity?.Name ?? "Kullanıcı")</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">
                                <i class="bi bi-box-arrow-right me-2"></i> Çıkış Yap
                            </a>
                        </li>
                    </ul>
                </div>

            </div>
        </div>
    </nav>

    <main class="flex-grow-1">
        <div class="container-fluid py-4">
            @RenderBody()
        </div>
    </main>

    <footer class="footer text-muted py-3 border-top">
        <div class="container-fluid d-flex justify-content-between align-items-center footer-inner">
            <span class="footer-brand">
                <span>© @DateTime.Now.Year</span>
                <span>Operasyon Takip Sistemi</span>
            </span>
            <span class="footer-version">@($"v{appVersion}")</span>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('table').forEach(function (table) {
                if (table.closest('.table-responsive')) {
                    return;
                }

                var wrapper = document.createElement('div');
                wrapper.className = 'table-responsive';
                table.parentNode.insertBefore(wrapper, table);
                wrapper.appendChild(table);
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>

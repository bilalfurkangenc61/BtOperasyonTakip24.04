@model IEnumerable<BtOperasyonTakip.Models.Parametre>
@{
    ViewData["Title"] = "Parametreler";
    var turler = (IEnumerable<string>)(ViewBag.Turler ?? new List<string>());
    var durumParametreleri = (IEnumerable<BtOperasyonTakip.Models.Parametre>)(ViewBag.DurumParametreleri ?? new List<BtOperasyonTakip.Models.Parametre>());
    var durumListesi = durumParametreleri.ToList();
    var isAdmin = User.IsInRole("Admin");
    var toplamParametre = Model?.Count() ?? 0;
    var toplamTur = turler.Count();

    static string GetDurumIcon(string? durum) => (durum ?? string.Empty).Trim() switch
    {
        "Beklemede" => "⏳",
        "Aktif" => "🚀",
        "Döküman İletildi" => "📄",
        "Tamamlandı" => "✅",
        _ => "•"
    };
}

<style>
    .parametre-shell {
        max-width: 1180px;
        overflow-x: hidden;
    }

    .parametre-hero {
        background: linear-gradient(135deg, #0f172a 0%, #2563eb 100%);
        color: #fff;
        border-radius: 1.1rem;
        padding: 1.35rem 1.5rem;
        box-shadow: 0 1rem 2rem rgba(37, 99, 235, 0.16);
    }

    .parametre-hero .hero-subtext {
        color: rgba(255, 255, 255, 0.82);
        font-size: 0.92rem;
    }

    .parametre-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.12);
        font-weight: 600;
    }

    .parametre-card {
        border: 0;
        border-radius: 1rem;
        box-shadow: 0 0.75rem 1.5rem rgba(15, 23, 42, 0.08);
        overflow: hidden;
    }

    .parametre-card .card-header {
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        border-bottom: 1px solid #e9eef5;
        padding: 1rem 1.25rem;
    }

    .parametre-card .card-body {
        padding: 1.25rem;
    }

    .parametre-card .form-control,
    .parametre-card .form-select,
    .parametre-card .btn {
        border-radius: 0.8rem;
    }

    .parametre-table-card .card-body {
        padding: 0;
    }

    .parametre-table {
        margin-bottom: 0;
    }

    .parametre-table thead th {
        white-space: nowrap;
        background: #f8fafc;
    }

    .durum-card {
        border: 1px solid #dbe7fb;
        border-radius: 1rem;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        box-shadow: 0 0.75rem 1.5rem rgba(15, 23, 42, 0.06);
    }

    .durum-list {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
    }

    .durum-order-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.28rem 0.6rem;
        border-radius: 999px;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #1d4ed8;
        font-size: 0.74rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .durum-item {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 0.85rem;
        align-items: center;
        border: 1px solid #e6edf7;
        border-radius: 0.8rem;
        background: rgba(255, 255, 255, 0.9);
        min-width: 0;
        padding: 0.75rem 0.85rem;
    }

    .durum-item-main {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        min-width: 0;
        flex: 1 1 auto;
    }

    .durum-icon {
        width: 2rem;
        height: 2rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        font-size: 1rem;
    }

    .durum-name {
        font-weight: 700;
        color: #0f172a;
        word-break: break-word;
        font-size: 0.95rem;
    }

    .durum-meta {
        color: #64748b;
        font-size: 0.76rem;
    }

    .durum-actions {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
    }

    .durum-actions form {
        margin: 0;
    }

    .durum-helper {
        color: #64748b;
        font-size: 0.84rem;
    }
</style>

<div class="container mt-4 parametre-shell">
    <div class="parametre-hero mb-4 d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <h2 class="mb-1" data-i18n="Parametre Yönetimi">Parametre Yönetimi</h2>
            <div class="hero-subtext" data-i18n="Sistem içindeki tür ve parametre değerlerini merkezi olarak yönetin.">Sistem içindeki tür ve parametre değerlerini merkezi olarak yönetin.</div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <span class="parametre-chip"><span data-i18n="Toplam Parametre">Toplam Parametre</span>: @toplamParametre</span>
            <span class="parametre-chip"><span data-i18n="Toplam Tür">Toplam Tür</span>: @toplamTur</span>
        </div>
    </div>

    @if (isAdmin)
    {
        <div class="row g-4 mb-4">
            <div class="col-lg-7">
                <div class="card parametre-card h-100">
                    <div class="card-header">
                        <div class="fw-semibold text-primary" data-i18n="Yeni Parametre">Yeni Parametre</div>
                        <div class="small text-muted" data-i18n="Mevcut bir türe yeni parametre değeri ekleyin.">Mevcut bir türe yeni parametre değeri ekleyin.</div>
                    </div>
                    <div class="card-body">
                        <form asp-action="Index" method="post" class="row g-3">
                            @Html.AntiForgeryToken()
                            <div class="col-md-5">
                                <label class="form-label" data-i18n="Parametre Adı">Parametre Adı</label>
                                <input name="ParAdi" class="form-control" placeholder="Örnek: .NET" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" data-i18n="Tür">Tür</label>
                                <select name="Tur" id="turSelect" class="form-select" required>
                                    <option value="" data-i18n="Seçiniz">Seçiniz</option>
                                    @foreach (var t in turler)
                                    {
                                        <option value="@t">@t</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3 d-flex align-items-end">
                                <button type="submit" class="btn btn-success w-100" data-i18n="Ekle">Ekle</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card parametre-card h-100">
                    <div class="card-header">
                        <div class="fw-semibold text-primary" data-i18n="Yeni Tür">Yeni Tür</div>
                        <div class="small text-muted" data-i18n="Parametre grupları için yeni tür tanımlayın.">Parametre grupları için yeni tür tanımlayın.</div>
                    </div>
                    <div class="card-body">
                        <form asp-action="TurEkle" method="post" class="row g-3">
                            @Html.AntiForgeryToken()
                            <div class="col-md-8">
                                <label class="form-label" data-i18n="Yeni Tür Ekle">Yeni Tür Ekle</label>
                                <input name="tur" class="form-control" placeholder="Örnek: Öncelik" />
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary w-100" data-i18n="Tür Ekle">Tür Ekle</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="card durum-card mb-4">
            <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <div class="fw-semibold text-primary" data-i18n="Durum Yönetimi">Durum Yönetimi</div>
                    <div class="small text-muted" data-i18n="İş Takip ekranındaki kolon sırasını ve durum görünümünü buradan yönetin.">İş Takip ekranındaki kolon sırasını ve durum görünümünü buradan yönetin.</div>
                </div>
                <div class="durum-helper" data-i18n="Yukarı / aşağı butonları kolon sırasını belirler.">Yukarı / aşağı butonları kolon sırasını belirler.</div>
            </div>
            <div class="card-body">
                @if (durumListesi.Any())
                {
                    <div class="durum-list">
                        @for (var i = 0; i < durumListesi.Count; i++)
                        {
                            var durum = durumListesi[i];
                            var isFirst = i == 0;
                            var isLast = i == durumListesi.Count - 1;

                            <div class="durum-item">
                                <div class="durum-item-main">
                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                        <span class="durum-icon">@GetDurumIcon(durum.ParAdi)</span>
                                        <div>
                                            <div class="durum-name">@durum.ParAdi</div>
                                            <div class="durum-meta" data-i18n="İş Takip kolonu olarak görünür">İş Takip kolonu olarak görünür</div>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center gap-2 flex-wrap mt-2">
                                        <span class="durum-order-badge">Sıra @(i + 1)</span>
                                        <span class="durum-meta">Kayıt No: #@durum.Id</span>
                                    </div>
                                </div>

                                <div class="durum-actions">
                                    <form asp-action="MoveDurum" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@durum.Id" />
                                        <input type="hidden" name="direction" value="up" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary" title="Yukarı taşı" @(isFirst ? "disabled" : null)>↑ Yukarı</button>
                                    </form>
                                    <form asp-action="MoveDurum" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@durum.Id" />
                                        <input type="hidden" name="direction" value="down" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary" title="Aşağı taşı" @(isLast ? "disabled" : null)>↓ Aşağı</button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                        <div class="alert alert-info mb-0"><span data-i18n="Henüz">Henüz</span> <strong data-i18n="Durum">Durum</strong> <span data-i18n="türünde parametre tanımlı değil.">türünde parametre tanımlı değil.</span></div>
                }
            </div>
        </div>
    }

    <div class="card parametre-card parametre-table-card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <div class="fw-semibold text-primary" data-i18n="Parametre Listesi">Parametre Listesi</div>
                <div class="small text-muted" data-i18n="Tanımlı türler ve parametre değerleri">Tanımlı türler ve parametre değerleri</div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle parametre-table">
                    <thead class="table-secondary">
                        <tr>
                            <th>ID</th>
                            <th data-i18n="Ad">Ad</th>
                            <th data-i18n="Tür">Tür</th>
                            <th data-i18n="İşlem">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td>@p.Id</td>
                                <td>@p.ParAdi</td>
                                <td>@p.Tur</td>
                                <td>
                                    @if (isAdmin)
                                    {
                                        <form asp-action="Delete" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@p.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger" data-i18n="Sil">Sil</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3" id="durumHelper" style="display:none;">
        <div class="alert alert-info mb-0">
            <strong data-i18n="Durum">Durum</strong> <span data-i18n="değerleri parametrelerden çekilir.">değerleri parametrelerden çekilir.</span> (`Parametreler` tablosu / `Tur = "Durum"`)
        </div>
    </div>

</div>

@model IEnumerable<BtOperasyonTakip.Models.Parametre>
@{
    ViewData["Title"] = "Parametreler";
    var turler = (IEnumerable<string>)(ViewBag.Turler ?? new List<string>());
    var isAdmin = User.IsInRole("Admin");
    var toplamParametre = Model?.Count() ?? 0;
    var toplamTur = turler.Count();
}

<style>
    .parametre-shell {
        max-width: 1450px;
    }

    .parametre-hero {
        background: linear-gradient(135deg, #0f172a 0%, #2563eb 100%);
        color: #fff;
        border-radius: 1.1rem;
        padding: 1.35rem 1.5rem;
        box-shadow: 0 1rem 2rem rgba(37, 99, 235, 0.16);
    }

    .parametre-hero .hero-subtext {
        color: rgba(255, 255, 255, 0.82);
        font-size: 0.92rem;
    }

    .parametre-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.12);
        font-weight: 600;
    }

    .parametre-card {
        border: 0;
        border-radius: 1rem;
        box-shadow: 0 0.75rem 1.5rem rgba(15, 23, 42, 0.08);
        overflow: hidden;
    }

    .parametre-card .card-header {
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        border-bottom: 1px solid #e9eef5;
        padding: 1rem 1.25rem;
    }

    .parametre-card .card-body {
        padding: 1.25rem;
    }

    .parametre-card .form-control,
    .parametre-card .form-select,
    .parametre-card .btn {
        border-radius: 0.8rem;
    }

    .parametre-table-card .card-body {
        padding: 0;
    }

    .parametre-table {
        margin-bottom: 0;
    }

    .parametre-table thead th {
        white-space: nowrap;
        background: #f8fafc;
    }
</style>

<div class="container mt-4 parametre-shell">
    <div class="parametre-hero mb-4 d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <h2 class="mb-1">Parametre Yönetimi</h2>
            <div class="hero-subtext">Sistem içindeki tür ve parametre değerlerini merkezi olarak yönetin.</div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <span class="parametre-chip">Toplam Parametre: @toplamParametre</span>
            <span class="parametre-chip">Toplam Tür: @toplamTur</span>
        </div>
    </div>

    @if (isAdmin)
    {
        <div class="row g-4 mb-4">
            <div class="col-lg-7">
                <div class="card parametre-card h-100">
                    <div class="card-header">
                        <div class="fw-semibold text-primary">Yeni Parametre</div>
                        <div class="small text-muted">Mevcut bir türe yeni parametre değeri ekleyin.</div>
                    </div>
                    <div class="card-body">
                        <form asp-action="Index" method="post" class="row g-3">
                            @Html.AntiForgeryToken()
                            <div class="col-md-5">
                                <label class="form-label">Parametre Adı</label>
                                <input name="ParAdi" class="form-control" placeholder="Örnek: .NET" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Tür</label>
                                <select name="Tur" id="turSelect" class="form-select" required>
                                    <option value="">Seçiniz</option>
                                    @foreach (var t in turler)
                                    {
                                        <option value="@t">@t</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3 d-flex align-items-end">
                                <button type="submit" class="btn btn-success w-100">Ekle</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card parametre-card h-100">
                    <div class="card-header">
                        <div class="fw-semibold text-primary">Yeni Tür</div>
                        <div class="small text-muted">Parametre grupları için yeni tür tanımlayın.</div>
                    </div>
                    <div class="card-body">
                        <form asp-action="TurEkle" method="post" class="row g-3">
                            @Html.AntiForgeryToken()
                            <div class="col-md-8">
                                <label class="form-label">Yeni Tür Ekle</label>
                                <input name="tur" class="form-control" placeholder="Örnek: Öncelik" />
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary w-100">Tür Ekle</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="card parametre-card parametre-table-card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <div class="fw-semibold text-primary">Parametre Listesi</div>
                <div class="small text-muted">Tanımlı türler ve parametre değerleri</div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle parametre-table">
                    <thead class="table-secondary">
                        <tr>
                            <th>ID</th>
                            <th>Ad</th>
                            <th>Tür</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td>@p.Id</td>
                                <td>@p.ParAdi</td>
                                <td>@p.Tur</td>
                                <td>
                                    @if (isAdmin)
                                    {
                                        <form asp-action="Delete" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@p.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3" id="durumHelper" style="display:none;">
        <div class="alert alert-info mb-0">
            <strong>Durum</strong> değerleri parametrelerden çekilir. (`Parametreler` tablosu / `Tur = "Durum"`)
        </div>
    </div>
</div>

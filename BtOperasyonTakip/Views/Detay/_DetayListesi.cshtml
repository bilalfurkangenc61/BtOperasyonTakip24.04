@model IEnumerable<BtOperasyonTakip.Models.Detay>
@{
    var kullaniciSecenekleri = ViewBag.KullaniciSecenekleri as IEnumerable<string> ?? Enumerable.Empty<string>();
    var mevcutKullanici = User?.Identity?.Name;
}

<div id="detayContainer" class="detay-container" data-musteri-id="@ViewBag.MusteriID">

    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">📋 Detaylar - @(string.IsNullOrWhiteSpace(ViewBag.MusteriAdi as string) ? "Müşteri" : ViewBag.MusteriAdi)</h5>
        </div>

        <div class="card-body">

            <form id="yeniDetayForm" method="post" action="@Url.Action("AddDetay", "Detay")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="MusteriID" value="@ViewBag.MusteriID" />
                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                <div class="row g-3 mb-4 p-3 bg-light rounded">
                    <div class="col-md-2">
                        <label class="form-label">Tarih / Saat</label>
                        <input type="datetime-local" name="Tarih" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">İş / Görüşülen</label>
                        <input type="text" name="Gorusulen" class="form-control" required />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Ekleyen</label>
                        <select name="Kekleyen" class="form-select">
                            <option value="">Seçiniz</option>
                            @foreach (var kisi in kullaniciSecenekleri)
                            {
                                <option value="@kisi" selected="@(string.Equals(kisi, mevcutKullanici, StringComparison.OrdinalIgnoreCase))">@kisi</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Açıklama</label>
                        <textarea name="Aciklama" class="form-control" rows="1" required></textarea>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">&nbsp;</label>
                        <button type="submit" class="btn btn-success w-100">➕ Ekle</button>
                    </div>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Tarih / Saat</th>
                            <th>İş / Görüşülen</th>
                            <th>Açıklama</th>
                            <th>Ekleyen</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var detay in Model)
                        {
                            <tr>
                                <td>@detay.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@detay.Gorusulen</td>
                                <td>@detay.Aciklama</td>
                                <td>@detay.Kekleyen</td>

                                <td>
                                    <button type="button" class="btn btn-sm btn-warning edit-detay-btn" data-id="@detay.DetayID" data-tarih="@detay.Tarih.ToString("yyyy-MM-ddTHH:mm")" data-gorusulen="@detay.Gorusulen" data-kekleyen="@detay.Kekleyen" data-aciklama="@detay.Aciklama">✏️</button>
                                    <form method="post" action="@Url.Action("DeleteDetay", "Detay")" class="d-inline delete-detay-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@detay.DetayID" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit" class="btn btn-sm btn-danger">❌</button>
                                    </form>

                                    @* Link to related archived tasks for this musteri/detay *@
                                    <a class="btn btn-sm btn-outline-primary ms-2" href="@Url.Action("Index", "TakipArsiv", new { q = ViewBag.MusteriAdi as string, ay = "", durum = "" })">Arşivde Göster</a>
                                </td>
                            </tr>
                        }

                        @if (!Model.Any())
                        {
                            <tr><td colspan="5" class="text-center text-muted">Henüz kayıt yok.</td></tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="detayEditModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-warning">
                <h5 class="modal-title">Detay Düzenle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="detayEditForm" method="post" action="@Url.Action("UpdateDetay", "Detay")">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="DetayID" id="editDetayID" />
                    <input type="hidden" name="MusteriID" value="@ViewBag.MusteriID" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                    <div class="mb-3">
                        <label>Tarih / Saat</label>
                        <input type="datetime-local" name="Tarih" id="editTarih" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label>İş / Görüşülen</label>
                        <input type="text" name="Gorusulen" id="editGorusulen" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label>Ekleyen</label>
                        <select name="Kekleyen" id="editKekleyen" class="form-select">
                            <option value="">Seçiniz</option>
                            @foreach (var kisi in kullaniciSecenekleri)
                            {
                                <option value="@kisi">@kisi</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label>Açıklama</label>
                        <textarea name="Aciklama" id="editAciklama" class="form-control"></textarea>
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
                <button type="submit" class="btn btn-primary" form="detayEditForm">Kaydet</button>
            </div>

        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.delete-detay-form').forEach(function (form) {
            form.addEventListener('submit', function (e) {
                if (!confirm('Bu kayıt silinsin mi?')) {
                    e.preventDefault();
                }
            });
        });

        document.querySelectorAll('.edit-detay-btn').forEach(function (button) {
            button.addEventListener('click', function () {
                document.getElementById('editDetayID').value = button.dataset.id || '';
                document.getElementById('editTarih').value = button.dataset.tarih || '';
                document.getElementById('editGorusulen').value = button.dataset.gorusulen || '';
                document.getElementById('editKekleyen').value = button.dataset.kekleyen || '';
                document.getElementById('editAciklama').value = button.dataset.aciklama || '';

                const modalElement = document.getElementById('detayEditModal');
                const modal = bootstrap.Modal.getOrCreateInstance(modalElement);
                modal.show();
            });
        });
    });
</script>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Yeni Ticket Oluştur";
}

@model BtOperasyonTakip.Models.Ticket

@{
    var selectedWebSitesiTipi = Context.Request.HasFormContentType
        ? Context.Request.Form["WebSitesiTipi"].ToString()
        : Model?.WebSitesiTipi;

    var selectedOdemeTurleri = (Context.Request.HasFormContentType
            ? Context.Request.Form["OdemeTurleri"].ToArray()
            : (Model?.OdemeTurleri ?? string.Empty).Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        .ToHashSet(StringComparer.OrdinalIgnoreCase);

    var selectedOdemeYontemleri = (Context.Request.HasFormContentType
            ? Context.Request.Form["OdemeYontemleri"].ToArray()
            : (Model?.OdemeYontemleri ?? string.Empty).Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        .ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<style>
    .ticket-create-shell {
        max-width: 1400px;
    }

    .ticket-create-hero {
        background: linear-gradient(135deg, #0f172a 0%, #2563eb 100%);
        color: #fff;
        border-radius: 1.15rem;
        padding: 1.4rem 1.5rem;
        box-shadow: 0 1rem 2rem rgba(37, 99, 235, 0.16);
    }

    .ticket-create-hero .hero-subtext {
        color: rgba(255, 255, 255, 0.82);
        font-size: 0.92rem;
    }

    .ticket-create-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.12);
        font-weight: 600;
    }

    .ticket-create-card {
        border: 0;
        border-radius: 1rem;
        box-shadow: 0 0.75rem 1.5rem rgba(15, 23, 42, 0.08);
        overflow: hidden;
    }

    .ticket-create-card .card-header {
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        border-bottom: 1px solid #e9eef5;
        padding: 1rem 1.25rem;
    }

    .ticket-create-card .card-body {
        padding: 1.25rem;
    }

    .ticket-create-card .form-control,
    .ticket-create-card .form-select,
    .ticket-create-card .btn {
        border-radius: 0.85rem;
    }

    .section-panel {
        border: 1px solid #e9eef5;
        border-radius: 1rem;
        padding: 1rem;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        height: 100%;
    }

    .section-panel-title {
        font-weight: 700;
        color: #1d4ed8;
        margin-bottom: 0.9rem;
    }

    .check-tile-wrap {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .action-bar {
        margin-top: 1.25rem;
        padding-top: 1rem;
        border-top: 1px solid #e9eef5;
    }

    .check-tile {
        position: relative;
    }

    .check-tile .form-check-input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
    }

    .check-tile .form-check-label {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 130px;
        padding: 0.75rem 0.95rem;
        border-radius: 0.9rem;
        border: 1px solid #dbe3ef;
        background: #fff;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s ease;
    }

    .check-tile .form-check-input:checked + .form-check-label {
        background: #eef4ff;
        border-color: #86b7fe;
        color: #1d4ed8;
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.08);
    }
</style>

<div class="container py-3 ticket-create-shell">
    <div class="ticket-create-hero mb-4 d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <h2 class="mb-1"><span aria-hidden="true">🆕</span> <span data-i18n="Yeni Ticket Oluştur">Yeni Ticket Oluştur</span></h2>
            <div class="hero-subtext" data-i18n="Müşteri, ödeme ve teknik bilgileri tek form üzerinden eksiksiz girin.">Müşteri, ödeme ve teknik bilgileri tek form üzerinden eksiksiz girin.</div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <span class="ticket-create-chip" data-i18n="Süreç başlangıcı: Operasyon 1">Süreç başlangıcı: Operasyon 1</span>
            <span class="ticket-create-chip" data-i18n="Müşteri tipi zorunlu">Müşteri tipi zorunlu</span>
        </div>
    </div>

    <div class="card ticket-create-card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <div class="fw-semibold text-primary" data-i18n="Ticket Bilgileri">Ticket Bilgileri</div>
                <div class="small text-muted" data-i18n="Zorunlu alanları doldurup kaydı oluşturun.">Zorunlu alanları doldurup kaydı oluşturun.</div>
            </div>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input asp-for="MusteriTipi" type="hidden" value="Kurumsal" />

                <div class="row g-4">
                    <div class="col-lg-7">
                        <div class="section-panel">
                            <div class="section-panel-title" data-i18n="Genel Bilgiler">Genel Bilgiler</div>
                            <div class="row">
                    <div class="col-md-12 mb-3">
                        <label asp-for="FirmaAdi" class="form-label fw-bold">
                            <span aria-hidden="true">🏢</span> <span data-i18n="Firma Adı">Firma Adı</span> <span class="text-danger">*</span>
                        </label>
                        <input asp-for="FirmaAdi" class="form-control" placeholder="Firma adı" required />
                        <span asp-validation-for="FirmaAdi" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold" data-i18n="Müşteri Ne Kullanacak?">Müşteri Ne Kullanacak? <span class="text-danger">*</span></label>
                        <div class="check-tile-wrap">
                        <div class="check-tile">
                            <input class="form-check-input" type="checkbox" name="OdemeTurleri" value="3D" id="odeme3d" checked="@selectedOdemeTurleri.Contains("3D")">
                            <label class="form-check-label" for="odeme3d">3D</label>
                        </div>
                        <div class="check-tile">
                            <input class="form-check-input" type="checkbox" name="OdemeTurleri" value="2D" id="odeme2d" checked="@selectedOdemeTurleri.Contains("2D")">
                            <label class="form-check-label" for="odeme2d">2D</label>
                        </div>
                        <div class="check-tile">
                            <input class="form-check-input" type="checkbox" name="OdemeTurleri" value="Linkli Ödeme" id="odemeLinkli" checked="@selectedOdemeTurleri.Contains("Linkli Ödeme")">
                            <label class="form-check-label" for="odemeLinkli">Linkli Ödeme</label>
                        </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold" data-i18n="Web Sitesi Kim Tarafından Yazıldı?">Web Sitesi Kim Tarafından Yazıldı? <span class="text-danger">*</span></label>
                        <select class="form-select" name="WebSitesiTipi" required>
                            <option value="" data-i18n="Seçiniz">Seçiniz</option>
                            <option value="Kendi Yazdı" selected="@(string.Equals(selectedWebSitesiTipi, "Kendi Yazdı", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Kendi Yazdı</option>
                            <option value="Hizmet Aldığı Firma" selected="@(string.Equals(selectedWebSitesiTipi, "Hizmet Aldığı Firma", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Hizmet Aldığı Firma</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-bold" data-i18n="Hangi Ödeme Yöntemleri Kullanılacak?">Hangi Ödeme Yöntemleri Kullanılacak? <span class="text-danger">*</span></label>
                        <div class="check-tile-wrap">
                        <div class="check-tile">
                            <input class="form-check-input" type="checkbox" name="OdemeYontemleri" value="Normal Çekim" id="odemeNormal" checked="@selectedOdemeYontemleri.Contains("Normal Çekim")">
                            <label class="form-check-label" for="odemeNormal">Normal Çekim</label>
                        </div>
                        <div class="check-tile">
                            <input class="form-check-input" type="checkbox" name="OdemeYontemleri" value="Previzyonlu Çekim" id="odemePrevizyonlu" checked="@selectedOdemeYontemleri.Contains("Previzyonlu Çekim")">
                            <label class="form-check-label" for="odemePrevizyonlu">Previzyonlu Çekim</label>
                        </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label asp-for="MusteriWebSitesi" class="form-label fw-bold">
                            <span aria-hidden="true">🌐</span> <span data-i18n="Müşteri Web Sitesi">Müşteri Web Sitesi</span> <span class="text-danger">*</span>
                        </label>
                        <input asp-for="MusteriWebSitesi" class="form-control" placeholder="https://example.com" required />
                        <span asp-validation-for="MusteriWebSitesi" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="YazilimciAdi" class="form-label fw-bold">
                            <span aria-hidden="true">👤</span> <span data-i18n="Yazılımcı Adı">Yazılımcı Adı</span> <span class="text-danger">*</span>
                        </label>
                        <input asp-for="YazilimciAdi" class="form-control" placeholder="Adı" required />
                        <span asp-validation-for="YazilimciAdi" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="YazilimciSoyadi" class="form-label fw-bold">
                            <span aria-hidden="true">👤</span> <span data-i18n="Yazılımcı Soyadı">Yazılımcı Soyadı</span> <span class="text-danger">*</span>
                        </label>
                        <input asp-for="YazilimciSoyadi" class="form-control" placeholder="Soyadı" required />
                        <span asp-validation-for="YazilimciSoyadi" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Mail" class="form-label fw-bold">
                            <span aria-hidden="true">📧</span> <span data-i18n="Mail Adresi">Mail Adresi</span> <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Mail" type="email" class="form-control" placeholder="ornek@mail.com" required />
                        <span asp-validation-for="Mail" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="IrtibatNumarasi" class="form-label fw-bold">
                            <span aria-hidden="true">📞</span> <span data-i18n="İrtibat Numarası">İrtibat Numarası</span> <span class="text-danger">*</span>
                        </label>
                        <input asp-for="IrtibatNumarasi" class="form-control" placeholder="+90 5XX XXX XXXX" required />
                        <span asp-validation-for="IrtibatNumarasi" class="text-danger"></span>
                    </div>
                </div>

                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="section-panel h-100">
                            <div class="section-panel-title" data-i18n="Süreç Özeti">Süreç Özeti</div>
                            <div class="small text-muted mb-3" data-i18n="Kayıt sonrası ticket doğrudan Operasyon 1 onay adımına düşer. Gerekli alanları eksiksiz doldurmanız süreci hızlandırır.">Kayıt sonrası ticket doğrudan Operasyon 1 onay adımına düşer. Gerekli alanları eksiksiz doldurmanız süreci hızlandırır.</div>

                            <div class="section-panel mb-3">
                                <div class="fw-semibold text-primary mb-2" data-i18n="Dikkat Edilecekler">Dikkat Edilecekler</div>
                                <ul class="mb-0 ps-3 small text-muted">
                                    <li data-i18n="Aynı firma, site veya mail için açık ticket varsa kayıt engellenir.">Aynı firma, site veya mail için açık ticket varsa kayıt engellenir.</li>
                                    <li data-i18n="Firma, web sitesi ve iletişim bilgileri eksiksiz girilmelidir.">Firma, web sitesi ve iletişim bilgileri eksiksiz girilmelidir.</li>
                                    <li data-i18n="Ödeme ve web sitesi seçimleri doğru işaretlenmelidir.">Ödeme ve web sitesi seçimleri doğru işaretlenmelidir.</li>
                                </ul>
                            </div>

                            <div class="section-panel">
                                <div class="fw-semibold text-primary mb-2" data-i18n="Aksiyonlar">Aksiyonlar</div>
                                <div class="d-grid gap-2">
                                    <button type="button" class="btn btn-outline-primary" onclick="window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });">
                                        <i class="bi bi-arrow-down-circle"></i> <span data-i18n="Aşağıdaki Gönder Butonuna Git">Aşağıdaki Gönder Butonuna Git</span>
                                    </button>
                                    <a asp-action="Index" class="btn btn-outline-secondary">
                                        <i class="bi bi-arrow-left"></i> <span data-i18n="Listeye Dön">Listeye Dön</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="action-bar d-flex flex-column flex-md-row gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> <span data-i18n="Geri">Geri</span>
                    </a>
                    <button type="submit" class="btn btn-primary btn-lg px-4">
                        <i class="bi bi-send-check"></i> <span data-i18n="Ticket Gönder">Ticket Gönder</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
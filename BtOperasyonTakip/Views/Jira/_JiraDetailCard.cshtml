@model BtOperasyonTakip.Models.JiraTask
@{
    var kullaniciList = ViewBag.KullaniciSecenekleri as List<string> ?? new List<string>();
    var taskLatestDetaylar = ViewBag.TaskLatestDetaylar as IDictionary<int, BtOperasyonTakip.Models.Detay?> ?? new Dictionary<int, BtOperasyonTakip.Models.Detay?>();
    var taskMusteriDurumlari = ViewBag.TaskMusteriDurumlari as IDictionary<int, string> ?? new Dictionary<int, string>();
    var sonDetay = taskLatestDetaylar.TryGetValue(Model.Id, out var latestDetay) ? latestDetay : null;
    var detayDurumu = taskMusteriDurumlari.TryGetValue(Model.Id, out var mevcutDetayDurumu) ? mevcutDetayDurumu : string.Empty;

    static (string Background, string Border, string Text) GetStatusPalette(string durum)
    {
        return durum switch
        {
            "Beklemede" => ("#fff7d6", "#ffe28a", "#8f5b00"),
            "Aktif" => ("#dbeafe", "#bfdbfe", "#1d4ed8"),
            "Döküman İletildi" => ("#f3e8ff", "#d8b4fe", "#7c3aed"),
            "Tamamlandı" => ("#e3fcef", "#abf5d1", "#006644"),
            _ => GetDynamicStatusPalette(durum)
        };
    };

    static (string Background, string Border, string Text) GetDynamicStatusPalette(string durum)
    {
        unchecked
        {
            var hash = 17;
            foreach (var ch in durum ?? string.Empty)
            {
                hash = (hash * 31) + ch;
            }

            var hue = Math.Abs(hash % 360);
            return (
                $"hsl({hue} 85% 96%)",
                $"hsl({hue} 70% 84%)",
                $"hsl({hue} 68% 34%)");
        }
    }

    var durumPalette = GetStatusPalette((Model.Durum ?? string.Empty).Trim());
}

<style>
    .jira-detail-card {
        border: 1px solid #e6edf7;
        border-radius: 22px;
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
        box-shadow: 0 16px 34px rgba(15, 23, 42, 0.08);
        overflow: hidden;
    }

    .jira-detail-topbar {
        height: 4px;
        background: linear-gradient(135deg, #0f172a 0%, #2563eb 100%);
    }

    .jira-detail-card .card-header {
        padding: 1rem 1.15rem;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        border-bottom: 1px solid #e6edf7;
    }

    .jira-header-meta-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.32rem 0.62rem;
        border-radius: 999px;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #1d4ed8;
        font-size: 0.72rem;
        font-weight: 800;
    }

    .jira-issue-key {
        font-size: 0.76rem;
        font-weight: 700;
        color: #0052cc;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 0.3rem;
    }

    .jira-issue-title {
        font-size: 1rem;
        font-weight: 700;
        color: #0f172a;
        line-height: 1.35;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
        overflow: hidden;
    }

    .jira-issue-subline {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem 0.85rem;
        margin-top: 0.45rem;
        color: #6b778c;
        font-size: 0.8rem;
    }

    .jira-status {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 0.38rem 0.7rem;
        font-size: 0.72rem;
        font-weight: 700;
        border: 1px solid transparent;
        white-space: nowrap;
    }

    .jira-detail-body {
        padding: 1.05rem 1.1rem 1.1rem;
    }

    .jira-detail-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 0.85rem;
        align-items: start;
    }

    .jira-side-stack {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
    }

    .jira-main-stack {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
        order: 2;
    }

    .jira-side-stack {
        order: 1;
    }

    .jira-section {
        border: 1px solid #e6edf7;
        border-radius: 18px;
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
        padding: 0.95rem;
    }

    .jira-section-title {
        font-size: 0.74rem;
        font-weight: 700;
        color: #2563eb;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.7rem;
    }

    .jira-section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 0.7rem;
    }

    .jira-section-head .jira-section-title {
        margin-bottom: 0;
    }

    .jira-count-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 30px;
        height: 30px;
        padding: 0 0.6rem;
        border-radius: 999px;
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        font-size: 0.72rem;
        font-weight: 800;
    }

    .jira-empty-note {
        border: 1px dashed #d5deea;
        border-radius: 12px;
        background: #fafcff;
        padding: 0.85rem;
        color: #6b778c;
        font-size: 0.88rem;
    }

    .jira-properties {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
    }

    .jira-detail-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
    }

    .jira-detail-tile {
        border: 1px solid #e6edf7;
        border-radius: 16px;
        background: linear-gradient(180deg, #ffffff 0%, #f9fbff 100%);
        padding: 0.85rem;
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.04);
    }

    .jira-detail-tile-label {
        color: #6b778c;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.35rem;
    }

    .jira-detail-tile-value {
        color: #172b4d;
        font-weight: 700;
        line-height: 1.35;
        font-size: 0.92rem;
        word-break: break-word;
    }

    .jira-detail-highlight {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        border: 1px dashed #bfdbfe;
        border-radius: 16px;
        background: linear-gradient(135deg, #eff6ff 0%, #f8fbff 100%);
        padding: 0.95rem;
    }

    .jira-detail-highlight-label {
        color: #2563eb;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .jira-detail-highlight-value {
        color: #172b4d;
        font-size: 0.95rem;
        font-weight: 700;
        word-break: break-word;
    }

    .jira-property-row {
        display: grid;
        grid-template-columns: 110px minmax(0, 1fr);
        gap: 0.85rem;
        align-items: start;
    }

    .jira-property-label {
        color: #6b778c;
        font-size: 0.78rem;
        font-weight: 700;
    }

    .jira-property-value {
        color: #172b4d;
        font-weight: 600;
        word-break: break-word;
    }

    .jira-assignee-box {
        border: 1px dashed #bfdbfe;
        border-radius: 16px;
        background: linear-gradient(135deg, #eff6ff 0%, #f8fbff 100%);
        padding: 0.9rem;
    }

    .jira-assignee-title {
        color: #2563eb;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.25rem;
    }

    .jira-assignee-current {
        color: #172b4d;
        font-size: 0.95rem;
        font-weight: 700;
        margin-bottom: 0.7rem;
        word-break: break-word;
    }

    .jira-comment-form .form-control,
    .jira-comment-form .form-select,
    .jira-detail-card .form-control,
    .jira-detail-card .form-select,
    .jira-detail-card .btn {
        border-radius: 12px;
        font-size: 0.9rem;
    }

    .jira-comments-list {
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .jira-comments-list li {
        position: relative;
        display: grid;
        grid-template-columns: 38px minmax(0, 1fr);
        gap: 0.7rem;
        border: 1px solid #e6edf7;
        border-radius: 18px;
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
        padding: 0.9rem;
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.04);
    }

    .jira-comments-list li::before {
        content: '';
        position: absolute;
        left: 1.15rem;
        top: 2.8rem;
        bottom: -0.8rem;
        width: 2px;
        background: linear-gradient(180deg, #bfdbfe 0%, #eff6ff 100%);
        border-radius: 999px;
    }

    .jira-comments-list li:last-child::before {
        display: none;
    }

    .jira-comment-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #0f172a 0%, #2563eb 100%);
        color: #fff;
        font-size: 0.85rem;
        font-weight: 800;
        box-shadow: 0 6px 14px rgba(37, 99, 235, 0.2);
        position: relative;
        z-index: 1;
    }

    .jira-comment-content {
        min-width: 0;
    }

    .jira-comment-meta {
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.4rem;
        align-items: flex-start;
        font-size: 0.8rem;
        margin-bottom: 0.35rem;
    }

    .jira-comment-author {
        color: #172b4d;
        font-weight: 700;
    }

    .jira-comment-date {
        display: inline-flex;
        align-items: center;
        padding: 0.2rem 0.5rem;
        border-radius: 999px;
        background: #f1f5f9;
        color: #64748b;
        font-size: 0.7rem;
        font-weight: 700;
    }

    .jira-comment-text {
        color: #0f172a;
        line-height: 1.45;
        white-space: pre-wrap;
        word-break: break-word;
        background: #fff;
        border: 1px solid #e6edf7;
        border-radius: 14px;
        padding: 0.8rem 0.9rem;
        font-size: 0.9rem;
    }

    .jira-comment-form .form-label {
        color: #6b778c;
        font-size: 0.72rem;
        font-weight: 700;
        margin-bottom: 0.25rem;
    }

    .jira-comment-form .btn {
        align-self: flex-start;
        padding-inline: 0.9rem;
        font-weight: 700;
    }

    @@media (min-width: 1200px) {
        .jira-detail-layout {
            grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.9fr);
            gap: 1rem;
        }

        .jira-main-stack {
            order: 1;
        }

        .jira-side-stack {
            order: 2;
            position: sticky;
            top: 1rem;
        }
    }

    @@media (max-width: 991.98px) {
        .jira-detail-grid {
            grid-template-columns: 1fr;
        }

        .jira-property-row {
            grid-template-columns: 1fr;
            gap: 0.2rem;
        }

        .jira-comments-list li {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="card jira-detail-card">
    <div class="jira-detail-topbar"></div>

    <div class="card-header d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div class="min-w-0">
            <div class="jira-issue-title">@Model.TalepKonusu</div>
            <div class="jira-issue-subline">
                @if (!string.IsNullOrWhiteSpace(Model.JiraId))
                {
                    <span class="jira-header-meta-pill">@Model.JiraId</span>
                }
                <span>Oluşturma: @Model.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")</span>
                <span>Talep Açan: @Model.TalepAcan</span>
            </div>
        </div>

        <span class="jira-status" style="background:@durumPalette.Background; border-color:@durumPalette.Border; color:@durumPalette.Text;">@Model.Durum</span>
    </div>

    <div class="jira-detail-body">
        <div class="jira-detail-layout">
            <div class="jira-main-stack">
                <div class="jira-section">
                    <div class="jira-section-head">
                        <div class="jira-section-title">Yorumlar</div>
                        <span class="jira-count-badge">@((Model.Yorumlar?.Count) ?? 0)</span>
                    </div>

                    @if (Model.Yorumlar != null && Model.Yorumlar.Any())
                    {
                        <ul class="jira-comments-list">
                            @foreach (var y in Model.Yorumlar.OrderByDescending(y => y.Tarih))
                            {
                                var commentAuthor = string.IsNullOrWhiteSpace(y.Ekleyen) ? "Sistem" : y.Ekleyen;
                                var commentInitial = commentAuthor.Substring(0, 1).ToUpperInvariant();

                                <li>
                                    <div class="jira-comment-avatar">@commentInitial</div>
                                    <div class="jira-comment-content">
                                        <div class="jira-comment-meta">
                                            <span class="jira-comment-author">@commentAuthor</span>
                                            <span class="jira-comment-date">@y.Tarih.ToString("dd.MM.yyyy HH:mm")</span>
                                        </div>
                                        <div class="jira-comment-text">@y.YorumMetni</div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="jira-empty-note">Henüz yorum yok.</div>
                    }
                </div>

                <div class="jira-section jira-comment-form">
                    <div class="jira-section-title">Aktivite Ekle</div>
                    <form method="post" action="@Url.Action("AddYorumForm", ViewContext.RouteData.Values["controller"]?.ToString())" class="d-flex flex-column gap-2 mt-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="jiraTaskId" value="@Model.Id" />
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                        <div>
                            <label class="form-label" for="yorum_@Model.Id">Yorum</label>
                            <textarea id="yorum_@Model.Id" class="form-control form-control-sm" name="yorum" rows="4" placeholder="Gelişme, not veya işlem bilgisini yaz..."></textarea>
                        </div>
                        <div>
                            <label class="form-label" for="ekleyen_@Model.Id">Ekleyen</label>
                            <select id="ekleyen_@Model.Id" class="form-select form-select-sm" name="ekleyen">
                                <option value="">Seçiniz</option>
                                @foreach (var kullanici in kullaniciList)
                                {
                                    <option value="@kullanici">@kullanici</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-sm btn-outline-primary">Yorum Ekle</button>
                    </form>
                </div>
            </div>

            <div class="jira-side-stack">
                <div class="jira-section">
                    <div class="jira-section-head">
                        <div class="jira-section-title">Detaylar</div>
                        <span class="jira-count-badge">6</span>
                    </div>
                    <div class="jira-properties">
                        <div class="jira-detail-highlight">
                            <div class="jira-detail-highlight-label">Talep Konusu</div>
                            <div class="jira-detail-highlight-value">@Model.TalepKonusu</div>
                        </div>

                        <div class="jira-detail-grid">
                            <div class="jira-detail-tile">
                                <div class="jira-detail-tile-label">Müşteri</div>
                                <div class="jira-detail-tile-value">@(string.IsNullOrWhiteSpace(Model.MusteriAdi) ? "-" : Model.MusteriAdi)</div>
                            </div>

                            <div class="jira-detail-tile">
                                <div class="jira-detail-tile-label">Talep Türü</div>
                                <div class="jira-detail-tile-value">@(string.IsNullOrWhiteSpace(Model.TalepTuru) ? "-" : Model.TalepTuru)</div>
                            </div>

                            <div class="jira-detail-tile">
                                <div class="jira-detail-tile-label">Talep Açan</div>
                                <div class="jira-detail-tile-value">@Model.TalepAcan</div>
                            </div>

                            <div class="jira-detail-tile">
                                <div class="jira-detail-tile-label">Oluşturma</div>
                                <div class="jira-detail-tile-value">@Model.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")</div>
                            </div>

                            <div class="jira-detail-tile">
                                <div class="jira-detail-tile-label">Son Detay</div>
                                <div class="jira-detail-tile-value">@(sonDetay == null ? "-" : sonDetay.Tarih.ToString("dd.MM.yyyy HH:mm"))</div>
                            </div>

                            <div class="jira-detail-tile">
                                <div class="jira-detail-tile-label">Detay Durumu</div>
                                <div class="jira-detail-tile-value">@(string.IsNullOrWhiteSpace(detayDurumu) ? "-" : detayDurumu)</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="jira-section">
                    <div class="jira-section-head">
                        <div class="jira-section-title">Takip Eden</div>
                        <span class="jira-count-badge">1</span>
                    </div>
                    <div class="jira-assignee-box">
                        <div class="jira-assignee-title">Mevcut atama</div>
                        <div class="jira-assignee-current">@(string.IsNullOrWhiteSpace(Model.TakipEden) ? "Atama yapılmadı" : Model.TakipEden)</div>

                        @if (User.IsInRole("Admin") || User.IsInRole("Operasyon"))
                        {
                            <form method="post" action="@Url.Action("AssignForm", ViewContext.RouteData.Values["controller"]?.ToString())" class="d-flex flex-column gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <input type="text"
                                       class="form-control form-control-sm"
                                       id="takipEdenSearch_@Model.Id"
                                       placeholder="Yazarak ara..."
                                       autocomplete="off" />
                                <select class="form-select form-select-sm" id="takipEdenSelect_@Model.Id" name="takipEden">
                                    <option value="">Seçiniz</option>
                                    @if (!string.IsNullOrWhiteSpace(Model.TakipEden) && !kullaniciList.Contains(Model.TakipEden))
                                    {
                                        <option value="@Model.TakipEden" selected>@Model.TakipEden</option>
                                    }
                                    @foreach (var kullanici in kullaniciList)
                                    {
                                        <option value="@kullanici" selected="@(string.Equals(Model.TakipEden, kullanici, StringComparison.Ordinal))">@kullanici</option>
                                    }
                                </select>
                                <button type="submit" class="btn btn-sm btn-primary">Kaydet</button>
                            </form>
                            <script>
                                (function () {
                                    const searchInput = document.getElementById('takipEdenSearch_@Model.Id');
                                    const select = document.getElementById('takipEdenSelect_@Model.Id');
                                    if (!searchInput || !select) return;

                                    const allOptions = Array.from(select.options).map(option => ({
                                        value: option.value,
                                        text: option.text,
                                        selected: option.selected
                                    }));

                                    const renderOptions = function (filterText) {
                                        const normalizedFilter = (filterText || '').trim().toLocaleLowerCase('tr-TR');
                                        const currentValue = select.value;
                                        let hasSelectedMatch = false;
                                        let firstMatchedValue = '';

                                        select.innerHTML = '';

                                        allOptions.forEach(option => {
                                            const isPlaceholder = option.value === '';
                                            const matches = isPlaceholder || option.text.toLocaleLowerCase('tr-TR').includes(normalizedFilter);

                                            if (!matches) return;

                                            const element = document.createElement('option');
                                            element.value = option.value;
                                            element.text = option.text;
                                            element.selected = option.value === currentValue;
                                            if (element.selected) {
                                                hasSelectedMatch = true;
                                            }

                                            if (!isPlaceholder && !firstMatchedValue) {
                                                firstMatchedValue = option.value;
                                            }

                                            select.appendChild(element);
                                        });

                                        if (select.options.length === 1 && select.options[0].value === '') {
                                            const emptyOption = document.createElement('option');
                                            emptyOption.value = '';
                                            emptyOption.text = 'Sonuç bulunamadı';
                                            select.appendChild(emptyOption);
                                        }

                                        if (normalizedFilter) {
                                            if (hasSelectedMatch) {
                                                select.value = currentValue;
                                            } else if (firstMatchedValue) {
                                                select.value = firstMatchedValue;
                                            }
                                        } else {
                                            select.value = currentValue;
                                        }
                                    };

                                    searchInput.addEventListener('input', function () {
                                        renderOptions(this.value);
                                    });

                                    renderOptions('');
                                })();
                            </script>
                        }
                        else
                        {
                            <div class="jira-property-value">@(string.IsNullOrWhiteSpace(Model.TakipEden) ? "-" : Model.TakipEden)</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
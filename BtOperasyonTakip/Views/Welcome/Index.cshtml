@{
    ViewData["Title"] = "Karşılama Sayfası";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/ui-localization.css" asp-append-version="true" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<style>
    body {
        font-family: 'Poppins', sans-serif;
        background: linear-gradient(135deg, #eaf1ff, #f6f9ff);
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .scene {
        display: none;
        text-align: center;
        animation: fadeIn 1s ease forwards;
    }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .typing {
        border-right: 2px solid #007bff;
        white-space: nowrap;
        overflow: hidden;
        animation: typing 2s steps(40, end), blink .75s step-end infinite;
    }

    @@keyframes typing {
        from

    {
        width: 0
    }

    to {
        width: 100%
    }

    }

    @@keyframes blink {
        from, to

    {
        border-color: transparent
    }

    50% {
        border-color: #007bff
    }

    }

    .clock {
        font-size: 2rem;
        font-weight: bold;
        color: #0056d6;
    }
</style>

<div class="container text-center">

    <div class="position-fixed top-0 end-0 p-3" style="z-index: 1055;" data-no-translate>
        <div class="language-switcher" style="background: rgba(15, 23, 42, 0.08); border-color: rgba(15,23,42,0.12);">
            <button type="button" class="language-switcher__button active" data-language-switch data-language-value="tr" aria-pressed="true" style="color:#0f172a;">TR</button>
            <button type="button" class="language-switcher__button" data-language-switch data-language-value="en" aria-pressed="false" style="color:#0f172a;">EN</button>
        </div>
    </div>

    <div id="scene1" class="scene">
        <div class="card p-4 shadow-lg border-0">
            <h3 class="typing text-primary fw-bold mb-3" id="loaderText"></h3>
        </div>
    </div>


    <div id="scene2" class="scene">
        <div class="card shadow-lg border-0 p-5">
            <h2 class="text-primary fw-bold mb-3">👋 <span id="welcomeUserText" data-user-name="@User.Identity?.Name">Hoş geldin, @User.Identity?.Name!</span></h2>
            <p class="lead text-muted" data-i18n="BT Operasyon Takip sistemine başarıyla giriş yaptın.">BT Operasyon Takip sistemine başarıyla giriş yaptın.</p>

            <div class="mt-4">
                <button id="enterBtn" class="btn btn-primary btn-lg">
                    🚀 <span data-i18n="Panele Giriş Yap">Panele Giriş Yap</span>
                </button>
                <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-danger btn-lg ms-2">
                    🔒 <span data-i18n="Çıkış Yap">Çıkış Yap</span>
                </a>
            </div>
        </div>
    </div>

    <div id="scene3" class="scene">
        <div class="card shadow-lg border-0 p-5 bg-light">
            <h2 class="text-primary mb-3" id="welcomeSceneTitle" data-i18n="Hoşgeldiniz">Hoşgeldiniz</h2>
            <div id="clock" class="clock mb-2"></div>
            <p class="lead text-success fw-semibold" id="motivasyonMetni"></p>
            <p class="text-muted" data-i18n="Yönlendiriliyor...">Yönlendiriliyor...</p>
        </div>
    </div>
</div>

<script>
   
    const loaderTexts = [
        "Sistemi başlatıyor...",
        "Veritabanı bağlantısı kuruluyor...",
        "Modüller yükleniyor...",
        "Dashboard hazırlanıyor...",
        
    ];
    let index = 0;

    function showTyping() {
        if (index < loaderTexts.length) {
            const text = loaderTexts[index];
            const el = document.getElementById("loaderText");
            el.textContent = "";
            let i = 0;
            const interval = setInterval(() => {
                el.textContent = text.substring(0, i++);
                if (i > text.length) {
                    clearInterval(interval);
                    index++;
                    setTimeout(showTyping, 1000);
                }
            }, 50);
        } else {
            setTimeout(() => {
                document.getElementById("scene1").style.display = "none";
                document.getElementById("scene2").style.display = "block";
            }, 500);
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        document.getElementById("scene1").style.display = "block";
        showTyping();

        document.getElementById("enterBtn")?.addEventListener("click", () => {
            document.getElementById("scene2").style.display = "none";
            document.getElementById("scene3").style.display = "block";
            startClock();
            showMotivasyon();
            setTimeout(() => window.location.href = "/Dashboard", 4000);
        });
    });

   
    function startClock() {
        const clock = document.getElementById("clock");
        setInterval(() => {
            const now = new Date();
            const culture = window.UiLocalization?.getLanguage?.() === 'en' ? 'en-US' : 'tr-TR';
            clock.textContent = now.toLocaleTimeString(culture, { hour: "2-digit", minute: "2-digit", second: "2-digit" });
        }, 1000);
    }

    function syncWelcomeTexts() {
        const language = window.UiLocalization?.getLanguage?.() ?? 'tr';
        const welcomeUserText = document.getElementById('welcomeUserText');
        const welcomeSceneTitle = document.getElementById('welcomeSceneTitle');

        if (welcomeUserText) {
            const userName = welcomeUserText.dataset.userName || '';
            welcomeUserText.textContent = language === 'en'
                ? `Welcome, ${userName}!`
                : `Hoş geldin, ${userName}!`;
        }

        if (welcomeSceneTitle) {
            welcomeSceneTitle.textContent = language === 'en' ? 'Welcome!' : 'Hoşgeldiniz!';
        }
    }

    function showMotivasyon() {
        const language = window.UiLocalization?.getLanguage?.() ?? 'tr';
        document.getElementById("motivasyonMetni").textContent = language === 'en' ? 'Welcome!' : 'Hoşgeldiniz!';
    }

    document.addEventListener('ui-language-changed', () => {
        syncWelcomeTexts();
        showMotivasyon();

        const clock = document.getElementById("clock");
        if (clock) {
            const now = new Date();
            const culture = window.UiLocalization?.getLanguage?.() === 'en' ? 'en-US' : 'tr-TR';
            clock.textContent = now.toLocaleTimeString(culture, { hour: "2-digit", minute: "2-digit", second: "2-digit" });
        }
    });

    document.addEventListener('DOMContentLoaded', syncWelcomeTexts);
</script>
<script src="~/js/ui-localization.js" asp-append-version="true"></script>

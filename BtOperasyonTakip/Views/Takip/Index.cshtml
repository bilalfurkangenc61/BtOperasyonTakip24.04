@section Scripts {
    <script>
        function normalizeStatus(s) { return (s || '').trim(); }

        const extraStatusStorageKey = 'takip-ekstra-durumlar';
        const anaDurumlar = @Html.Raw(Json.Serialize(anaDurumlar));
        const extraStatusOptions = @Html.Raw(Json.Serialize(ekstraDurumSecenekleri));
        const serverSelectedExtraStatuses = @Html.Raw(Json.Serialize(selectedEkstraDurumlar));

        function containsStatus(statusList, value) {
            const normalizedValue = normalizeStatus(value).toLocaleLowerCase('tr-TR');
            return statusList.some(x => normalizeStatus(x).toLocaleLowerCase('tr-TR') === normalizedValue);
        }

        function normalizeStatusList(values) {
            const result = [];

            (values || []).forEach(value => {
                const normalizedValue = normalizeStatus(value);
                if (!normalizedValue) {
                    return;
                }

                if (containsStatus(anaDurumlar, normalizedValue) || containsStatus(result, normalizedValue)) {
                    return;
                }

                result.push(normalizedValue);
            });

            return result;
        }

        function getStoredExtraStatuses() {
            try {
                const stored = JSON.parse(localStorage.getItem(extraStatusStorageKey) || '[]');
                return normalizeStatusList(Array.isArray(stored) ? stored : []);
            } catch {
                return [];
            }
        }

        function setStoredExtraStatuses(values) {
            localStorage.setItem(extraStatusStorageKey, JSON.stringify(normalizeStatusList(values)));
        }

        function ensureExtraStatusesInUrlFromStorage() {
            const currentParams = new URLSearchParams(window.location.search);
            const queryExtraStatuses = normalizeStatusList(currentParams.getAll('ekstraDurumlar'));
            const storedExtraStatuses = getStoredExtraStatuses();

            if (queryExtraStatuses.length > 0) {
                setStoredExtraStatuses(queryExtraStatuses);
                return false;
            }

            if (storedExtraStatuses.length === 0) {
                return false;
            }

            storedExtraStatuses.forEach(status => currentParams.append('ekstraDurumlar', status));
            const query = currentParams.toString();
            const newUrl = `${window.location.pathname}${query ? `?${query}` : ''}${window.location.hash}`;
            window.location.replace(newUrl);
            return true;
        }

        function setCardStatusClass(card, yeniDurum) {
            if (!card) return;
            card.classList.remove('status-beklemede', 'status-aktif', 'status-pasif', 'status-tamamlandi');

            const st = normalizeStatus(yeniDurum);
            if (st === 'Beklemede') card.classList.add('status-beklemede');
            else if (st === 'Aktif') card.classList.add('status-aktif');
            else if (st === 'Pasif') card.classList.add('status-pasif');
            else if (st === 'Tamamlandı') card.classList.add('status-tamamlandi');
        }

        function updateColumnCounts() {
            document.querySelectorAll('.board-col').forEach(col => {
                const status = col.getAttribute('data-status-col');
                const zone = col.querySelector('.dropzone');
                const count = zone ? zone.querySelectorAll('.task-card:not(.d-none)').length : 0;

                const badge = col.querySelector(`.board-col-count[data-count-for="${status}"]`);
                if (badge) badge.textContent = count.toString();
            });
        }

        function layoutBoardColumns(selected) {
            const cols = Array.from(document.querySelectorAll('.board-col'));
            const isSingle = selected && selected !== 'all';

            cols.forEach(col => {
                col.classList.toggle('d-none', isSingle && col.getAttribute('data-status-col') !== selected);

                if (isSingle && col.getAttribute('data-status-col') === selected) {
                    col.classList.remove('col-md-4');
                    col.classList.add('col-md-12');
                } else {
                    col.classList.remove('col-md-12');
                    col.classList.add('col-md-4');
                }
            });
        }

        function applyBoardStatusFilter() {
            const sel = document.getElementById('boardStatusFilter');
            const val = sel ? sel.value : 'all';
            layoutBoardColumns(val);
            updateColumnCounts();
        }

        function initializeMusteriSearch() {
            const searchInput = document.getElementById('musteriSearch');
            const musteriSelect = document.getElementById('musteriSelect');
            if (!searchInput || !musteriSelect) return;

            const allOptions = Array.from(musteriSelect.options).map(option => ({
                value: option.value,
                text: option.text,
                selected: option.selected
            }));

            const renderOptions = function (filterText) {
                const normalizedFilter = (filterText || '').trim().toLocaleLowerCase('tr-TR');
                const currentValue = musteriSelect.value;

                musteriSelect.innerHTML = '';

                allOptions.forEach(option => {
                    const isPlaceholder = option.value === '';
                    const matches = isPlaceholder || option.text.toLocaleLowerCase('tr-TR').includes(normalizedFilter);

                    if (!matches) return;

                    const element = document.createElement('option');
                    element.value = option.value;
                    element.text = option.text;
                    element.selected = option.value === currentValue || (currentValue === '' && option.selected);
                    musteriSelect.appendChild(element);
                });

                if (musteriSelect.options.length === 1 && musteriSelect.options[0].value === '') {
                    const emptyOption = document.createElement('option');
                    emptyOption.value = '';
                    emptyOption.text = 'Sonuç bulunamadı';
                    musteriSelect.appendChild(emptyOption);
                }
            };

            searchInput.addEventListener('input', function () {
                renderOptions(this.value);
            });

            const form = musteriSelect.closest('form');
            if (form) {
                form.addEventListener('reset', function () {
                    setTimeout(function () {
                        searchInput.value = '';
                        renderOptions('');
                    }, 0);
                });
            }

            renderOptions('');
        }

        function initializeFilterableSelect(searchInputId, selectId) {
            const searchInput = document.getElementById(searchInputId);
            const select = document.getElementById(selectId);
            if (!searchInput || !select) return;

            const allOptions = Array.from(select.options).map(option => ({
                value: option.value,
                text: option.text,
                selected: option.selected
            }));

            const renderOptions = function (filterText) {
                const normalizedFilter = (filterText || '').trim().toLocaleLowerCase('tr-TR');
                const currentValue = select.value;
                let hasSelectedMatch = false;
                let firstMatchedValue = '';

                select.innerHTML = '';

                allOptions.forEach(option => {
                    const isPlaceholder = option.value === '';
                    const matches = isPlaceholder || option.text.toLocaleLowerCase('tr-TR').includes(normalizedFilter);

                    if (!matches) return;

                    const element = document.createElement('option');
                    element.value = option.value;
                    element.text = option.text;
                    element.selected = option.value === currentValue;
                    if (element.selected) {
                        hasSelectedMatch = true;
                    }

                    if (!isPlaceholder && !firstMatchedValue) {
                        firstMatchedValue = option.value;
                    }

                    select.appendChild(element);
                });

                if (select.options.length === 1 && select.options[0].value === '') {
                    const emptyOption = document.createElement('option');
                    emptyOption.value = '';
                    emptyOption.text = 'Sonuç bulunamadı';
                    select.appendChild(emptyOption);
                }

                if (normalizedFilter) {
                    if (hasSelectedMatch) {
                        select.value = currentValue;
                    } else if (firstMatchedValue) {
                        select.value = firstMatchedValue;
                    }
                } else {
                    select.value = currentValue;
                }
            };

            searchInput.addEventListener('input', function () {
                renderOptions(this.value);
            });

            const form = select.closest('form');
            if (form) {
                form.addEventListener('reset', function () {
                    setTimeout(function () {
                        searchInput.value = '';
                        renderOptions('');
                    }, 0);
                });
            }

            renderOptions('');
        }

        function initializeExtraStatusPicker() {
            const form = document.getElementById('takipFilterForm');
            const select = document.getElementById('extraStatusSelect');
            const addButton = document.getElementById('addExtraStatusButton');
            const selectedContainer = document.getElementById('selectedExtraStatuses');
            const hiddenInputsContainer = document.getElementById('selectedExtraStatusInputs');

            if (!form || !select || !addButton || !selectedContainer || !hiddenInputsContainer) {
                return;
            }

            let selectedStatuses = normalizeStatusList(serverSelectedExtraStatuses.length > 0
                ? serverSelectedExtraStatuses
                : getStoredExtraStatuses());

            const render = function () {
                hiddenInputsContainer.innerHTML = '';
                selectedContainer.innerHTML = '';

                const label = document.createElement('span');
                label.className = 'takip-selected-statuses-label';
                label.setAttribute('data-i18n', 'Seçilen kolonlar');
                label.textContent = 'Seçilen kolonlar';
                selectedContainer.appendChild(label);

                selectedStatuses.forEach(status => {
                    const hiddenInput = document.createElement('input');
                    hiddenInput.type = 'hidden';
                    hiddenInput.name = 'ekstraDurumlar';
                    hiddenInput.value = status;
                    hiddenInputsContainer.appendChild(hiddenInput);

                    const chip = document.createElement('span');
                    chip.className = 'takip-selected-status-chip';

                    const text = document.createElement('span');
                    text.textContent = status;
                    chip.appendChild(text);

                    const removeButton = document.createElement('button');
                    removeButton.type = 'button';
                    removeButton.setAttribute('data-remove-status', status);
                    removeButton.setAttribute('aria-label', 'Sil');
                    removeButton.title = 'Sil';
                    removeButton.textContent = '×';
                    chip.appendChild(removeButton);

                    selectedContainer.appendChild(chip);
                });

                const availableOptions = normalizeStatusList(extraStatusOptions)
                    .filter(status => !containsStatus(selectedStatuses, status));

                select.innerHTML = '';

                const placeholder = document.createElement('option');
                placeholder.value = '';
                placeholder.setAttribute('data-i18n', 'Durum seçiniz');
                placeholder.textContent = 'Durum seçiniz';
                select.appendChild(placeholder);

                availableOptions.forEach(status => {
                    const option = document.createElement('option');
                    option.value = status;
                    option.textContent = status;
                    select.appendChild(option);
                });

                if (window.UiLocalization?.applyLanguage) {
                    window.UiLocalization.applyLanguage(window.UiLocalization.getLanguage());
                }
            };

            addButton.addEventListener('click', function () {
                const selectedValue = normalizeStatus(select.value);
                if (!selectedValue || containsStatus(selectedStatuses, selectedValue)) {
                    return;
                }

                selectedStatuses.push(selectedValue);
                selectedStatuses = normalizeStatusList(selectedStatuses);
                setStoredExtraStatuses(selectedStatuses);
                render();
                form.requestSubmit();
            });

            selectedContainer.addEventListener('click', function (event) {
                const button = event.target instanceof Element ? event.target.closest('[data-remove-status]') : null;
                if (!button) {
                    return;
                }

                const statusToRemove = button.getAttribute('data-remove-status');
                selectedStatuses = selectedStatuses.filter(status => !containsStatus([status], statusToRemove));
                setStoredExtraStatuses(selectedStatuses);
                render();
                form.requestSubmit();
            });

            form.addEventListener('submit', function () {
                setStoredExtraStatuses(selectedStatuses);
            });

            render();
        }

        if (!ensureExtraStatusesInUrlFromStorage()) {
            const boardStatusFilter = document.getElementById('boardStatusFilter');
            if (boardStatusFilter) boardStatusFilter.addEventListener('change', applyBoardStatusFilter);

            document.querySelectorAll('.board-col-status').forEach(s => {
                s.addEventListener('change', (e) => {
                    const topFilter = document.getElementById('boardStatusFilter');
                    if (topFilter) topFilter.value = e.currentTarget.value;
                    applyBoardStatusFilter();
                });
            });

            initializeMusteriSearch();
            initializeFilterableSelect('talepAcanSearch', 'talepAcanSelect');
            initializeFilterableSelect('takipEdenSearch', 'takipEdenSelect');
            initializeExtraStatusPicker();

            const selectedTaskDetail = document.getElementById('selectedTaskDetail');
            const urlParams = new URLSearchParams(window.location.search);
            if (selectedTaskDetail && urlParams.get('focusDetail') === '1') {
                setTimeout(function () {
                    selectedTaskDetail.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }, 120);
            }
        }

    </script>
}

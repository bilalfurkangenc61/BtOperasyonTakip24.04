@model BtOperasyonTakip.Models.JiraBoardViewModel
@{
    ViewData["Title"] = "İş Takip";

    var beklemedeCount = Model?.Beklemede?.Count ?? 0;
    var aktifCount = Model?.Aktif?.Count ?? 0;
    var tamamlandiCount = Model?.Tamamlandi?.Count ?? 0;
    var totalCount = beklemedeCount + aktifCount + tamamlandiCount;

    var talepAcanList = Model?.TalepAcanSecenekleri ?? new List<string>();
    var takipEdenList = Model?.TakipEdenSecenekleri ?? new List<string>();

    var q = Model?.Q ?? "";
    var currentPage = Model?.Page ?? 1;
    var pageSize = Model?.PageSize ?? 10;
    var totalPages = Model?.TotalPages ?? 1;
    var totalDbCount = Model?.TotalCount ?? 0;
}

<style>
    .takip-shell {
        max-width: 1600px;
    }

    .takip-hero {
        background: linear-gradient(135deg, #0f172a 0%, #2563eb 100%);
        color: #fff;
        border-radius: 18px;
        padding: 1.4rem 1.5rem;
        box-shadow: 0 18px 32px rgba(37, 99, 235, 0.14);
    }

    .takip-hero-subtext {
        color: rgba(255, 255, 255, 0.82);
        font-size: 0.92rem;
    }

    .takip-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.12);
        font-weight: 600;
    }

    .takip-card {
        border: 0;
        border-radius: 18px;
        box-shadow: 0 14px 28px rgba(15, 23, 42, 0.08);
        overflow: hidden;
    }

    .takip-card .card-header {
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        border-bottom: 1px solid #e6edf7;
        padding: 1rem 1.2rem;
    }

    .takip-card .card-body {
        padding: 1.2rem;
    }

    .takip-card .form-control,
    .takip-card .form-select,
    .takip-card .btn,
    .takip-card .page-link {
        border-radius: 12px;
    }

    .responsive-select {
        width: auto;
    }

    .kanban-board {
        display: flex;
        gap: 1rem;
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 0.5rem;
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
    }

    .kanban-board::-webkit-scrollbar {
        height: 10px;
    }

    .kanban-board::-webkit-scrollbar-thumb {
        background: #9db8f755;
        border-radius: 999px;
    }

    .board-col {
        flex: 0 0 380px;
        max-width: 380px;
        width: 380px;
        display: flex;
        flex-direction: column;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        border: 1px solid #e6edf7;
        border-radius: 18px;
        box-shadow: 0 12px 24px rgba(15, 23, 42, 0.07);
        padding: 0.9rem;
    }

    .kanban-board .board-col.col-md-12 {
        flex-basis: 100%;
        max-width: none;
        width: 100%;
    }

    .board-col-header {
        position: sticky;
        top: 0;
        z-index: 1;
        padding: 0.25rem 0.2rem 0.85rem;
        border-bottom: 1px solid #edf2f7;
        margin-bottom: 0.85rem;
    }

    .dropzone {
        min-height: 160px;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
    }

    .task-card {
        border: 1px solid #e4ebf5;
        border-left-width: 5px;
        border-radius: 16px;
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.06);
        transition: transform 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease;
        cursor: grab;
        overflow: hidden;
        background: #fff;
    }

    .task-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 28px rgba(15, 23, 42, 0.1);
        background: #fbfdff;
    }

    .task-card .card-body {
        padding: 1rem;
    }

    .task-card.status-beklemede {
        border-left-color: #f59e0b;
    }

    .task-card.status-aktif {
        border-left-color: #2563eb;
    }

    .task-card.status-tamamlandi {
        border-left-color: #22c55e;
    }

    .task-detail {
        width: 100%;
    }

    .board-col h5 {
        font-size: 1rem;
        font-weight: 700;
    }

    @@media (max-width: 767.98px) {
        .takip-hero {
            padding: 1.15rem;
        }

        .kanban-board {
            gap: 0.75rem;
        }

        .board-col {
            flex-basis: min(88vw, 380px);
            max-width: min(88vw, 380px);
            width: min(88vw, 380px);
        }

        .responsive-select {
            width: 100%;
        }

        .board-col-header {
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .task-card .card-body > .d-flex,
        .task-card .small.d-flex,
        .task-card .mt-2.d-flex {
            flex-wrap: wrap;
        }
    }

    .musteri-select {
        min-height: 220px;
    }
</style>

<div class="container py-2 takip-shell">
    <div class="takip-hero mb-4 d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
        <div>
            <h4 class="mb-1 text-white">İş Takip</h4>
            <div class="takip-hero-subtext">
                Bu sayfa: <strong>@totalCount</strong> iş —
                Toplam (DB): <strong>@totalDbCount</strong> iş
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 align-items-center">
            <span class="takip-chip">Beklemede: @beklemedeCount</span>
            <span class="takip-chip">Aktif: @aktifCount</span>
            <span class="takip-chip">Tamamlandı: @tamamlandiCount</span>

            <a class="btn btn-sm btn-light fw-semibold"
               href="@Url.Action("ExportExcelGrouped", "Takip", new { q = q })">
                Excel (JiraId Gruplu)
            </a>
        </div>
    </div>

    @if (TempData["JiraOk"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["JiraOk"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    @if (TempData["JiraError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["JiraError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    <div class="card takip-card mb-4">
        <div class="card-header bg-white">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div class="fw-semibold">İş Ekle</div>
                <div class="text-muted small">Durum varsayılan: Beklemede</div>
            </div>
        </div>
        <div class="card-body">
            <form asp-controller="Takip" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="row g-2">
                    <div class="col-md-3">
                        <label class="form-label">Müşteri</label>
                        <input type="text"
                               id="musteriSearch"
                               class="form-control mb-2"
                               placeholder="Müşteri ara..."
                               autocomplete="off" />

                        <select id="musteriSelect" name="MusteriID" class="form-select musteri-select" size="8">
                            <option value="">Seçiniz</option>
                            @foreach (var musteri in Model.MusteriSecenekleri)
                            {
                                <option value="@musteri.MusteriID">@musteri.Firma</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">İş Tipi</label>
                        <select name="TalepTuru" class="form-select">
                            <option value="">Seçiniz</option>
                            <option value="Geliştirme">Geliştirme</option>
                            <option value="Eğitim">Eğitim</option>
                             <option value="Entegrasyon">Entegrasyon</option>
                             <option value="Hata Çözüm">Hata Çözüm</option>
                        </select>
                    </div>

                    <div class="col-md-7">
                        <label class="form-label">Talep Konusu</label>
                        <textarea name="TalepKonusu" class="form-control" rows="4" maxlength="4000" placeholder="Talep konusunu detaylı yazın..." required></textarea>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Talep Açan</label>
                        <input type="text" id="talepAcanSearch" class="form-control mb-2" placeholder="Yazarak ara..." autocomplete="off" />
                        <select id="talepAcanSelect" name="TalepAcan" class="form-select">
                            <option value="">Seçiniz</option>
                            @foreach (var p in talepAcanList)
                            {
                                <option value="@p">@p</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Takip Eden</label>
                        <input type="text" id="takipEdenSearch" class="form-control mb-2" placeholder="Yazarak ara..." autocomplete="off" />
                        <select id="takipEdenSelect" name="TakipEden" class="form-select">
                            <option value="">Seçiniz</option>
                            @foreach (var p in takipEdenList)
                            {
                                <option value="@p">@p</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Ekle</button>
                    <button type="reset" class="btn btn-outline-secondary">Sıfırla</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card takip-card mb-4">
        <div class="card-body">
            <form method="get" asp-controller="Takip" asp-action="Index" class="row align-items-end g-2">
                <div class="col-md-6">
                    <label for="taskSearch" class="form-label">Ara (server-side)</label>
                    <input id="taskSearch" name="q" value="@q" type="text" class="form-control"
                           placeholder="Konu / Açan / Takip Eden / Durum..." autocomplete="off" />
                </div>

                <div class="col-md-6 d-flex justify-content-md-end gap-2 flex-wrap">
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@pageSize" />

                    <div class="d-flex flex-column align-items-md-end">
                        <label for="boardStatusFilter" class="form-label mb-1">Kolon Filtre</label>
                        <select id="boardStatusFilter" class="form-select form-select-sm responsive-select">
                            <option value="all" selected>Tümü</option>
                            <option value="Beklemede">Beklemede</option>
                            <option value="Aktif">Aktif</option>
                            <option value="Tamamlandı">Tamamlandı</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary align-self-end">Ara</button>

                    <a class="btn btn-outline-secondary align-self-end"
                       href="@Url.Action("Index", "Takip", new { page = 1, pageSize = pageSize })">Temizle</a>

                    <div class="text-muted align-self-end small">
                        Sayfa: <strong>@currentPage</strong>/<strong>@totalPages</strong>
                    </div>
                </div>
            </form>

            <nav class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3" aria-label="Sayfalama">
                <div class="text-muted small">
                    Toplam (DB): <strong>@totalDbCount</strong> kayıt —
                    Sayfa: <strong>@currentPage</strong> / <strong>@totalPages</strong> —
                    Sayfa boyutu: <strong>@pageSize</strong>
                </div>

                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", "Takip", new { q = q, page = currentPage - 1, pageSize = pageSize })">Önceki</a>
                    </li>

                    @for (var i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", "Takip", new { q = q, page = i, pageSize = pageSize })">@i</a>
                        </li>
                    }

                    <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", "Takip", new { q = q, page = currentPage + 1, pageSize = pageSize })">Sonraki</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>

    <div class="kanban-board" id="board">
        <div class="col-md-4 board-col" data-status-col="Beklemede">
            <div class="board-col-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <h5 class="mb-0">Beklemede</h5>
                    <span class="badge text-bg-secondary board-col-count" data-count-for="Beklemede">@beklemedeCount</span>
                </div>
                <select class="form-select form-select-sm board-col-status responsive-select" aria-label="Kolon seç">
                    <option value="Beklemede" selected>Beklemede</option>
                    <option value="Aktif">Aktif</option>
                    <option value="Tamamlandı">Tamamlandı</option>
                </select>
            </div>

            <div class="dropzone mt-2" data-status="Beklemede">
                @foreach (var t in Model.Beklemede)
                {
                    <div class="card draggable task-card status-beklemede" draggable="true" data-id="@t.Id">
                        <div class="card-body">
                            <div class="fw-bold">@t.TalepKonusu</div>

                            <div class="small text-muted mt-1">Müşteri: @(string.IsNullOrWhiteSpace(t.MusteriAdi) ? "-" : t.MusteriAdi)</div>
                            <div class="small text-muted">Tür: @(string.IsNullOrWhiteSpace(t.TalepTuru) ? "-" : t.TalepTuru)</div>

                            <div class="small text-muted mt-1">Açan: @t.TalepAcan</div>
                            <div class="small text-muted">Takip Eden: <span class="takip-eden-text">@(string.IsNullOrWhiteSpace(t.TakipEden) ? "-" : t.TakipEden)</span></div>

                            <div class="small text-muted d-flex align-items-center gap-2 mt-2">
                                <span>Durum:</span>
                                <form method="post" action="@Url.Action("UpdateDurumForm", "Takip")" class="d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path?selectedTaskId=@t.Id&q=@q&page=@currentPage&pageSize=@pageSize" />
                                    <select name="yeniDurum" class="form-select form-select-sm responsive-select" onchange="this.form.submit()">
                                        <option value="Beklemede" selected="@(t.Durum?.Trim().Equals("Beklemede", StringComparison.OrdinalIgnoreCase) == true)">Beklemede</option>
                                        <option value="Aktif" selected="@(t.Durum?.Trim().Equals("Aktif", StringComparison.OrdinalIgnoreCase) == true)">Aktif</option>
                                        <option value="Tamamlandı" selected="@(t.Durum?.Trim().Equals("Tamamlandı", StringComparison.OrdinalIgnoreCase) == true)">Tamamlandı</option>
                                    </select>
                                </form>
                            </div>

                            <div class="mt-2 d-flex gap-2">
                                <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Index", "Takip", new { q = q, selectedTaskId = t.Id, page = currentPage, pageSize = pageSize })">Detay</a>
                                <form method="post" action="@Url.Action("DeleteForm", "Takip")" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path?q=@q&page=@currentPage&pageSize=@pageSize" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bu kaydı silmek istiyor musunuz?');">Sil</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-4 board-col" data-status-col="Aktif">
            <div class="board-col-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <h5 class="mb-0">Aktif</h5>
                    <span class="badge text-bg-primary board-col-count" data-count-for="Aktif">@aktifCount</span>
                </div>
                <select class="form-select form-select-sm board-col-status responsive-select" aria-label="Kolon seç">
                    <option value="Beklemede">Beklemede</option>
                    <option value="Aktif" selected>Aktif</option>
                    <option value="Tamamlandı">Tamamlandı</option>
                </select>
            </div>

            <div class="dropzone mt-2" data-status="Aktif">
                @foreach (var t in Model.Aktif)
                {
                    <div class="card draggable task-card status-aktif" draggable="true" data-id="@t.Id">
                        <div class="card-body">
                            <div class="fw-bold">@t.TalepKonusu</div>

                            <div class="small text-muted mt-1">Müşteri: @(string.IsNullOrWhiteSpace(t.MusteriAdi) ? "-" : t.MusteriAdi)</div>
                            <div class="small text-muted">Tür: @(string.IsNullOrWhiteSpace(t.TalepTuru) ? "-" : t.TalepTuru)</div>

                            <div class="small text-muted mt-1">Açan: @t.TalepAcan</div>
                            <div class="small text-muted">Takip Eden: <span class="takip-eden-text">@(string.IsNullOrWhiteSpace(t.TakipEden) ? "-" : t.TakipEden)</span></div>

                            <div class="small text-muted d-flex align-items-center gap-2 mt-2">
                                <span>Durum:</span>
                                <form method="post" action="@Url.Action("UpdateDurumForm", "Takip")" class="d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path?selectedTaskId=@t.Id&q=@q&page=@currentPage&pageSize=@pageSize" />
                                    <select name="yeniDurum" class="form-select form-select-sm responsive-select" onchange="this.form.submit()">
                                        <option value="Beklemede" selected="@(t.Durum?.Trim().Equals("Beklemede", StringComparison.OrdinalIgnoreCase) == true)">Beklemede</option>
                                        <option value="Aktif" selected="@(t.Durum?.Trim().Equals("Aktif", StringComparison.OrdinalIgnoreCase) == true)">Aktif</option>
                                        <option value="Tamamlandı" selected="@(t.Durum?.Trim().Equals("Tamamlandı", StringComparison.OrdinalIgnoreCase) == true)">Tamamlandı</option>
                                    </select>
                                </form>
                            </div>

                            <div class="mt-2 d-flex gap-2">
                                <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Index", "Takip", new { q = q, selectedTaskId = t.Id, page = currentPage, pageSize = pageSize })">Detay</a>
                                <form method="post" action="@Url.Action("DeleteForm", "Takip")" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path?q=@q&page=@currentPage&pageSize=@pageSize" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bu kaydı silmek istiyor musunuz?');">Sil</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-4 board-col" data-status-col="Tamamlandı">
            <div class="board-col-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <h5 class="mb-0">Tamamlandı</h5>
                    <span class="badge text-bg-success board-col-count" data-count-for="Tamamlandı">@tamamlandiCount</span>
                </div>
                <select class="form-select form-select-sm board-col-status responsive-select" aria-label="Kolon seç">
                    <option value="Beklemede">Beklemede</option>
                    <option value="Aktif">Aktif</option>
                    <option value="Tamamlandı" selected>Tamamlandı</option>
                </select>
            </div>

            <div class="dropzone mt-2" data-status="Tamamlandı">
                @foreach (var t in Model.Tamamlandi)
                {
                    <div class="card draggable task-card status-tamamlandi" draggable="true" data-id="@t.Id">
                        <div class="card-body">
                            <div class="fw-bold">@t.TalepKonusu</div>

                            <div class="small text-muted mt-1">Müşteri: @(string.IsNullOrWhiteSpace(t.MusteriAdi) ? "-" : t.MusteriAdi)</div>
                            <div class="small text-muted">Tür: @(string.IsNullOrWhiteSpace(t.TalepTuru) ? "-" : t.TalepTuru)</div>

                            <div class="small text-muted mt-1">Açan: @t.TalepAcan</div>
                            <div class="small text-muted">Takip Eden: <span class="takip-eden-text">@(string.IsNullOrWhiteSpace(t.TakipEden) ? "-" : t.TakipEden)</span></div>

                            <div class="small text-muted d-flex align-items-center gap-2 mt-2">
                                <span>Durum:</span>
                                <form method="post" action="@Url.Action("UpdateDurumForm", "Takip")" class="d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path?selectedTaskId=@t.Id&q=@q&page=@currentPage&pageSize=@pageSize" />
                                    <select name="yeniDurum" class="form-select form-select-sm responsive-select" onchange="this.form.submit()">
                                        <option value="Beklemede" selected="@(t.Durum?.Trim().Equals("Beklemede", StringComparison.OrdinalIgnoreCase) == true)">Beklemede</option>
                                        <option value="Aktif" selected="@(t.Durum?.Trim().Equals("Aktif", StringComparison.OrdinalIgnoreCase) == true)">Aktif</option>
                                        <option value="Tamamlandı" selected="@(t.Durum?.Trim().Equals("Tamamlandı", StringComparison.OrdinalIgnoreCase) == true)">Tamamlandı</option>
                                    </select>
                                </form>
                            </div>

                            <div class="mt-2 d-flex gap-2">
                                <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Index", "Takip", new { q = q, selectedTaskId = t.Id, page = currentPage, pageSize = pageSize })">Detay</a>
                                <form method="post" action="@Url.Action("DeleteForm", "Takip")" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path?q=@q&page=@currentPage&pageSize=@pageSize" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bu kaydı silmek istiyor musunuz?');">Sil</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (Model.SelectedTask != null)
    {
        <div class="mt-4 task-detail">
            @await Html.PartialAsync("~/Views/Jira/_JiraDetailCard.cshtml", Model.SelectedTask)
        </div>
    }
</div>

@section Scripts {
    <script>
        function normalizeStatus(s) { return (s || '').trim(); }

        function setCardStatusClass(card, yeniDurum) {
            if (!card) return;
            card.classList.remove('status-beklemede', 'status-aktif', 'status-tamamlandi');

            const st = normalizeStatus(yeniDurum);
            if (st === 'Beklemede') card.classList.add('status-beklemede');
            else if (st === 'Aktif') card.classList.add('status-aktif');
            else if (st === 'Tamamlandı') card.classList.add('status-tamamlandi');
        }

        function updateColumnCounts() {
            document.querySelectorAll('.board-col').forEach(col => {
                const status = col.getAttribute('data-status-col');
                const zone = col.querySelector('.dropzone');
                const count = zone ? zone.querySelectorAll('.task-card:not(.d-none)').length : 0;

                const badge = col.querySelector(`.board-col-count[data-count-for="${status}"]`);
                if (badge) badge.textContent = count.toString();
            });
        }

        function layoutBoardColumns(selected) {
            const cols = Array.from(document.querySelectorAll('.board-col'));
            const isSingle = selected && selected !== 'all';

            cols.forEach(col => {
                col.classList.toggle('d-none', isSingle && col.getAttribute('data-status-col') !== selected);

                if (isSingle && col.getAttribute('data-status-col') === selected) {
                    col.classList.remove('col-md-4');
                    col.classList.add('col-md-12');
                } else {
                    col.classList.remove('col-md-12');
                    col.classList.add('col-md-4');
                }
            });
        }

        function applyBoardStatusFilter() {
            const sel = document.getElementById('boardStatusFilter');
            const val = sel ? sel.value : 'all';
            layoutBoardColumns(val);
            updateColumnCounts();
        }

        function initializeMusteriSearch() {
            const searchInput = document.getElementById('musteriSearch');
            const musteriSelect = document.getElementById('musteriSelect');
            if (!searchInput || !musteriSelect) return;

            const allOptions = Array.from(musteriSelect.options).map(option => ({
                value: option.value,
                text: option.text,
                selected: option.selected
            }));

            const renderOptions = function (filterText) {
                const normalizedFilter = (filterText || '').trim().toLocaleLowerCase('tr-TR');
                const currentValue = musteriSelect.value;

                musteriSelect.innerHTML = '';

                allOptions.forEach(option => {
                    const isPlaceholder = option.value === '';
                    const matches = isPlaceholder || option.text.toLocaleLowerCase('tr-TR').includes(normalizedFilter);

                    if (!matches) return;

                    const element = document.createElement('option');
                    element.value = option.value;
                    element.text = option.text;
                    element.selected = option.value === currentValue || (currentValue === '' && option.selected);
                    musteriSelect.appendChild(element);
                });

                if (musteriSelect.options.length === 1 && musteriSelect.options[0].value === '') {
                    const emptyOption = document.createElement('option');
                    emptyOption.value = '';
                    emptyOption.text = 'Sonuç bulunamadı';
                    musteriSelect.appendChild(emptyOption);
                }
            };

            searchInput.addEventListener('input', function () {
                renderOptions(this.value);
            });

            const form = musteriSelect.closest('form');
            if (form) {
                form.addEventListener('reset', function () {
                    setTimeout(function () {
                        searchInput.value = '';
                        renderOptions('');
                    }, 0);
                });
            }

            renderOptions('');
        }

        function initializeFilterableSelect(searchInputId, selectId) {
            const searchInput = document.getElementById(searchInputId);
            const select = document.getElementById(selectId);
            if (!searchInput || !select) return;

            const allOptions = Array.from(select.options).map(option => ({
                value: option.value,
                text: option.text,
                selected: option.selected
            }));

            const renderOptions = function (filterText) {
                const normalizedFilter = (filterText || '').trim().toLocaleLowerCase('tr-TR');
                const currentValue = select.value;
                let hasSelectedMatch = false;
                let firstMatchedValue = '';

                select.innerHTML = '';

                allOptions.forEach(option => {
                    const isPlaceholder = option.value === '';
                    const matches = isPlaceholder || option.text.toLocaleLowerCase('tr-TR').includes(normalizedFilter);

                    if (!matches) return;

                    const element = document.createElement('option');
                    element.value = option.value;
                    element.text = option.text;
                    element.selected = option.value === currentValue;
                    if (element.selected) {
                        hasSelectedMatch = true;
                    }

                    if (!isPlaceholder && !firstMatchedValue) {
                        firstMatchedValue = option.value;
                    }

                    select.appendChild(element);
                });

                if (select.options.length === 1 && select.options[0].value === '') {
                    const emptyOption = document.createElement('option');
                    emptyOption.value = '';
                    emptyOption.text = 'Sonuç bulunamadı';
                    select.appendChild(emptyOption);
                }

                if (normalizedFilter) {
                    if (hasSelectedMatch) {
                        select.value = currentValue;
                    } else if (firstMatchedValue) {
                        select.value = firstMatchedValue;
                    }
                } else {
                    select.value = currentValue;
                }
            };

            searchInput.addEventListener('input', function () {
                renderOptions(this.value);
            });

            const form = select.closest('form');
            if (form) {
                form.addEventListener('reset', function () {
                    setTimeout(function () {
                        searchInput.value = '';
                        renderOptions('');
                    }, 0);
                });
            }

            renderOptions('');
        }

        const boardStatusFilter = document.getElementById('boardStatusFilter');
        if (boardStatusFilter) boardStatusFilter.addEventListener('change', applyBoardStatusFilter);

        document.querySelectorAll('.board-col-status').forEach(s => {
            s.addEventListener('change', (e) => {
                const topFilter = document.getElementById('boardStatusFilter');
                if (topFilter) topFilter.value = e.currentTarget.value;
                applyBoardStatusFilter();
            });
        });

        initializeMusteriSearch();
        initializeFilterableSelect('talepAcanSearch', 'talepAcanSelect');
        initializeFilterableSelect('takipEdenSearch', 'takipEdenSelect');

    </script>
}

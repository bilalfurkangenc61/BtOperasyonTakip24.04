@model BtOperasyonTakip.Models.JiraBoardViewModel
@{
    ViewData["Title"] = "İş Takip";

    var beklemedeCount = Model?.Beklemede?.Count ?? 0;
    var aktifCount = Model?.Aktif?.Count ?? 0;
    var tamamlandiCount = Model?.Tamamlandi?.Count ?? 0;
    var dokumanIletildiList = (ViewBag.DokumanIletildiTasks as List<BtOperasyonTakip.Models.JiraTask>) ?? new List<BtOperasyonTakip.Models.JiraTask>();
    var dokumanIletildiCount = dokumanIletildiList.Count;
    var totalCount = beklemedeCount + aktifCount + tamamlandiCount + dokumanIletildiCount;

    var talepAcanList = Model?.TalepAcanSecenekleri ?? new List<string>();
    var takipEdenList = Model?.TakipEdenSecenekleri ?? new List<string>();
    var kisiList = (ViewBag.KisiSecenekleri as List<string>) ?? new List<string>();
    var selectedKisi = (ViewBag.SelectedKisi as string) ?? "";

    var q = Model?.Q ?? "";
    var currentPage = Model?.Page ?? 1;
    var pageSize = Model?.PageSize ?? 10;
    var totalPages = Model?.TotalPages ?? 1;
    var totalDbCount = Model?.TotalCount ?? 0;
}

<style>
    .takip-shell {
        max-width: 1680px;
    }

    .takip-shell .alert {
        border-radius: 16px;
        border: 0;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }

    .takip-hero {
        background: linear-gradient(135deg, #0f172a 0%, #2563eb 100%);
        color: #fff;
        border-radius: 24px;
        padding: 1.6rem;
        box-shadow: 0 22px 40px rgba(37, 99, 235, 0.16);
    }

    .takip-hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.38rem 0.7rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.14);
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-bottom: 0.85rem;
    }

    .takip-hero-title {
        font-size: 1.55rem;
        font-weight: 800;
        line-height: 1.15;
        margin-bottom: 0.45rem;
    }

    .takip-hero-subtext {
        color: rgba(255, 255, 255, 0.82);
        font-size: 0.94rem;
        max-width: 760px;
    }

    .takip-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.6rem 0.9rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.12);
        font-weight: 600;
    }

    .takip-kpi-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 0.9rem;
        margin-top: 1rem;
    }

    .takip-kpi {
        border: 1px solid #e6edf7;
        border-radius: 20px;
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
        box-shadow: 0 14px 28px rgba(15, 23, 42, 0.06);
        padding: 1rem 1.1rem;
    }

    .takip-kpi-label {
        color: #64748b;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .takip-kpi-value {
        color: #0f172a;
        font-size: 1.4rem;
        font-weight: 800;
        line-height: 1.1;
        margin-top: 0.35rem;
    }

    .takip-kpi-note {
        color: #64748b;
        font-size: 0.82rem;
        margin-top: 0.3rem;
    }

    .takip-card {
        border: 1px solid #e8eef8;
        border-radius: 22px;
        box-shadow: 0 16px 34px rgba(15, 23, 42, 0.07);
        overflow: hidden;
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    }

    .takip-card .card-header {
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        border-bottom: 1px solid #e6edf7;
        padding: 1rem 1.25rem;
    }

    .takip-section-title {
        font-size: 1rem;
        font-weight: 700;
        color: #0f172a;
    }

    .takip-section-subtitle {
        color: #64748b;
        font-size: 0.85rem;
    }

    .takip-filter-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.5rem 0.85rem;
        border-radius: 999px;
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        font-weight: 700;
        font-size: 0.85rem;
    }

    .takip-card .card-body {
        padding: 1.1rem 1.25rem 1.25rem;
    }

    .takip-card .form-control,
    .takip-card .form-select,
    .takip-card .btn,
    .takip-card .page-link {
        border-radius: 12px;
    }

    .takip-card .form-label {
        font-size: 0.82rem;
        font-weight: 700;
        color: #475569;
        margin-bottom: 0.4rem;
    }

    .takip-form-block {
        border: 1px solid #e8eef8;
        border-radius: 18px;
        background: linear-gradient(180deg, #ffffff 0%, #f9fbff 100%);
        padding: 0.9rem;
        height: 100%;
    }

    .takip-form-block.takip-form-block-tall {
        min-height: 100%;
    }

    .takip-form-helper {
        color: #64748b;
        font-size: 0.78rem;
        margin-top: 0.25rem;
    }

    .takip-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 0.9rem;
    }

    .takip-toolbar-note {
        color: #64748b;
        font-size: 0.84rem;
    }

    .responsive-select {
        width: auto;
    }

    .kanban-board {
        display: flex;
        gap: 1rem;
        overflow-x: auto;
        overflow-y: hidden;
        padding-bottom: 0.5rem;
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
    }

    .kanban-board::-webkit-scrollbar {
        height: 10px;
    }

    .kanban-board::-webkit-scrollbar-thumb {
        background: #9db8f755;
        border-radius: 999px;
    }

    .board-col {
        flex: 0 0 360px;
        max-width: 360px;
        width: 360px;
        display: flex;
        flex-direction: column;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        border: 1px solid #e6edf7;
        border-radius: 22px;
        box-shadow: 0 14px 28px rgba(15, 23, 42, 0.07);
        padding: 0.95rem;
    }

    .kanban-board .board-col.col-md-12 {
        flex-basis: 100%;
        max-width: none;
        width: 100%;
    }

    .board-col-header {
        position: sticky;
        top: 0;
        z-index: 1;
        padding: 0.2rem 0.1rem 0.8rem;
        border-bottom: 1px solid #edf2f7;
        margin-bottom: 0.85rem;
        background: linear-gradient(180deg, rgba(255,255,255,.98) 0%, rgba(248,251,255,.96) 100%);
        backdrop-filter: blur(6px);
    }

    .board-col-subtitle {
        color: #64748b;
        font-size: 0.76rem;
        margin-top: 0.12rem;
    }

    .board-count-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 34px;
        height: 34px;
        padding: 0 0.75rem;
        border-radius: 999px;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #1d4ed8;
        font-size: 0.84rem;
        font-weight: 800;
    }

    .dropzone {
        min-height: 180px;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
    }

    .board-empty-state {
        border: 1px dashed #dbe5f1;
        border-radius: 16px;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        color: #64748b;
        text-align: center;
        padding: 1.1rem 0.9rem;
        font-size: 0.86rem;
    }

    .task-card {
        border: 1px solid #e4ebf5;
        border-left-width: 5px;
        border-radius: 18px;
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.06);
        transition: transform 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease;
        cursor: grab;
        overflow: hidden;
        background: linear-gradient(180deg, #ffffff 0%, #fcfdff 100%);
    }

    .task-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 28px rgba(15, 23, 42, 0.1);
        background: #fbfdff;
    }

    .task-card.task-selected {
        box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.18), 0 16px 32px rgba(37, 99, 235, 0.16);
        animation: selectedTaskPulse 2.2s ease-out 1;
    }

    .task-card .card-body {
        padding: 0.95rem;
    }

    .task-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.75rem;
    }

    .task-title {
        font-size: 0.97rem;
        font-weight: 700;
        color: #0f172a;
        line-height: 1.35;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
        overflow: hidden;
    }

    .task-id-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 0.32rem 0.6rem;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #1d4ed8;
        font-size: 0.72rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .task-badge {
        display: inline-flex;
        align-items: center;
        max-width: 100%;
        padding: 0.34rem 0.65rem;
        border-radius: 999px;
        background: #f8fbff;
        border: 1px solid #e3ebf8;
        color: #475569;
        font-size: 0.74rem;
        font-weight: 600;
    }

    .task-meta-row {
        display: grid;
        grid-template-columns: 90px minmax(0, 1fr);
        gap: 0.6rem;
        align-items: flex-start;
        font-size: 0.82rem;
        color: #475569;
        padding-top: 0.2rem;
    }

    .task-meta-label {
        color: #64748b;
        font-weight: 700;
    }

    .task-meta-value {
        color: #0f172a;
        font-weight: 700;
        word-break: break-word;
    }

    .task-actions .btn {
        border-radius: 10px;
        font-weight: 600;
    }

    .task-status-row {
        padding-top: 0.6rem;
        margin-top: 0.45rem;
        border-top: 1px dashed #e5edf7;
    }

    .task-card.status-beklemede {
        border-left-color: #f59e0b;
    }

    .task-card.status-aktif {
        border-left-color: #2563eb;
    }

    .task-card.status-tamamlandi {
        border-left-color: #22c55e;
    }

    .task-card.status-dokuman-iletildi {
        border-left-color: #8b5cf6;
    }

    .task-detail {
        width: 100%;
        margin-top: 1.1rem;
        scroll-margin-top: 1.25rem;
    }

    .task-detail.task-detail-highlight {
        animation: detailRevealGlow 2.2s ease-out 1;
    }

    .board-col h5 {
        font-size: 0.98rem;
        font-weight: 700;
    }

    .takip-pagination-note {
        color: #64748b;
        font-size: 0.82rem;
    }

    @@keyframes selectedTaskPulse {
        0% {
            transform: translateY(-2px) scale(1.01);
            box-shadow: 0 0 0 0 rgba(37, 99, 235, 0.28), 0 20px 36px rgba(37, 99, 235, 0.18);
        }
        100% {
            transform: translateY(0) scale(1);
        }
    }

    @@keyframes detailRevealGlow {
        0% {
            box-shadow: 0 0 0 0 rgba(37, 99, 235, 0.2);
        }
        40% {
            box-shadow: 0 0 0 6px rgba(37, 99, 235, 0.08);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(37, 99, 235, 0);
        }
    }

    @@media (max-width: 767.98px) {
        .takip-hero {
            padding: 1.2rem;
        }

        .takip-hero-title {
            font-size: 1.25rem;
        }

        .takip-kpi-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .kanban-board {
            gap: 0.75rem;
        }

        .board-col {
            flex-basis: min(90vw, 360px);
            max-width: min(90vw, 360px);
            width: min(90vw, 360px);
        }

        .responsive-select {
            width: 100%;
        }

        .board-col-header {
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .task-head {
            flex-direction: column;
        }

        .task-card .card-body > .d-flex,
        .task-card .small.d-flex,
        .task-card .mt-2.d-flex {
            flex-wrap: wrap;
        }

        .task-meta-row {
            grid-template-columns: 1fr;
            gap: 0.2rem;
        }

        .takip-toolbar {
            flex-direction: column;
            align-items: flex-start;
        }
    }

</style>

<div class="container py-2 takip-shell">
    <div class="takip-hero mb-4 d-flex flex-column gap-4">
        <div class="d-flex flex-column flex-xl-row align-items-xl-center justify-content-between gap-3">
            <div>
                <div class="takip-hero-eyebrow">Operasyon · İş Takip</div>
                <div class="takip-hero-title">İş akışını daha hızlı yönetin</div>
                <div class="takip-hero-subtext">
                    Kişi bazlı görünüm, hızlı filtreleme, görev durumu güncelleme ve detay takibini tek ekranda yönetin.
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="takip-chip">Görünüm: @(string.IsNullOrWhiteSpace(selectedKisi) ? "Tüm Kişiler" : selectedKisi)</span>
                <span class="takip-chip">Toplam: @totalDbCount</span>

                <a class="btn btn-sm btn-light fw-semibold"
                   href="@Url.Action("ExportExcelGrouped", "Takip", new { q = q, kisi = selectedKisi })">
                    Excel (JiraId Gruplu)
                </a>
            </div>
        </div>

        <div class="takip-kpi-grid">
            <div class="takip-kpi">
                <div class="takip-kpi-label">Bu Sayfa</div>
                <div class="takip-kpi-value">@totalCount</div>
                <div class="takip-kpi-note">Filtre sonrası görünen iş</div>
            </div>
            <div class="takip-kpi">
                <div class="takip-kpi-label">Beklemede</div>
                <div class="takip-kpi-value">@beklemedeCount</div>
                <div class="takip-kpi-note">Aksiyon bekleyen kayıt</div>
            </div>
            <div class="takip-kpi">
                <div class="takip-kpi-label">Aktif</div>
                <div class="takip-kpi-value">@aktifCount</div>
                <div class="takip-kpi-note">Devam eden iş</div>
            </div>
            <div class="takip-kpi">
                <div class="takip-kpi-label">Tamamlandı</div>
                <div class="takip-kpi-value">@tamamlandiCount</div>
                <div class="takip-kpi-note">Kapanmış iş</div>
            </div>
            <div class="takip-kpi">
                <div class="takip-kpi-label">Döküman İletildi</div>
                <div class="takip-kpi-value">@dokumanIletildiCount</div>
                <div class="takip-kpi-note">Döküman paylaşılmış işler</div>
            </div>
        </div>
    </div>

    @if (TempData["JiraOk"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["JiraOk"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    @if (TempData["JiraError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["JiraError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    <div class="card takip-card mb-4">
        <div class="card-header bg-white">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div>
                    <div class="takip-section-title">İş Ekle</div>
                    <div class="takip-section-subtitle">Yeni talebi kompakt form ile hızlıca ekleyin</div>
                </div>
                <div class="takip-filter-pill">Durum varsayılan: Beklemede</div>
            </div>
        </div>
        <div class="card-body">
            <form asp-controller="Takip" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="row g-3 align-items-stretch">
                    <div class="col-xl-4 col-lg-5">
                        <div class="takip-form-block takip-form-block-tall">
                            <label class="form-label">Müşteri</label>
                            <input type="text"
                                   id="musteriSearch"
                                   class="form-control mb-2"
                                   placeholder="Müşteri ara..."
                                   autocomplete="off" />

                            <select id="musteriSelect" name="MusteriID" class="form-select">
                                <option value="">Seçiniz</option>
                                @foreach (var musteri in Model.MusteriSecenekleri)
                                {
                                    <option value="@musteri.MusteriID">@musteri.Firma</option>
                                }
                            </select>
                            <div class="takip-form-helper">Listeden seçilen müşteri otomatik iş kaydına bağlanır.</div>
                        </div>
                    </div>

                    <div class="col-xl-8 col-lg-7">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="takip-form-block">
                                    <label class="form-label">İş Tipi</label>
                                    <select name="TalepTuru" class="form-select">
                                        <option value="">Seçiniz</option>
                                        <option value="Geliştirme">Geliştirme</option>
                                        <option value="Eğitim">Eğitim</option>
                                        <option value="Entegrasyon">Entegrasyon</option>
                                        <option value="Hata Çözüm">Hata Çözüm</option>
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-8">
                                <div class="takip-form-block">
                                    <label class="form-label">Talep Konusu</label>
                                    <textarea name="TalepKonusu" class="form-control" rows="4" maxlength="4000" placeholder="Talep konusunu detaylı yazın..." required></textarea>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="takip-form-block">
                                    <label class="form-label">Talep Açan</label>
                                    <input type="text" id="talepAcanSearch" class="form-control mb-2" placeholder="Yazarak ara..." autocomplete="off" />
                                    <select id="talepAcanSelect" name="TalepAcan" class="form-select">
                                        <option value="">Seçiniz</option>
                                        @foreach (var p in talepAcanList)
                                        {
                                            <option value="@p">@p</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="takip-form-block">
                                    <label class="form-label">Takip Eden</label>
                                    <input type="text" id="takipEdenSearch" class="form-control mb-2" placeholder="Yazarak ara..." autocomplete="off" />
                                    <select id="takipEdenSelect" name="TakipEden" class="form-select">
                                        <option value="">Seçiniz</option>
                                        @foreach (var p in takipEdenList)
                                        {
                                            <option value="@p">@p</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Ekle</button>
                    <button type="reset" class="btn btn-outline-secondary">Sıfırla</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card takip-card mb-4">
        <div class="card-header bg-white">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                <div>
                    <div class="takip-section-title">Filtreler ve görünüm</div>
                    <div class="takip-section-subtitle">Kişi, arama, kolon görünümü ve sayfalamayı buradan yönetin</div>
                </div>
                <div class="takip-filter-pill">
                    Kişi: @(string.IsNullOrWhiteSpace(selectedKisi) ? "Tümü" : selectedKisi)
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="takip-toolbar">
                <div class="takip-toolbar-note">
                    Aktif filtreler sayfa, detay, silme ve durum güncelleme işlemlerinde korunur.
                </div>
                <div class="takip-pagination-note">
                    Toplam (DB): <strong>@totalDbCount</strong> kayıt · Sayfa <strong>@currentPage</strong>/<strong>@totalPages</strong>
                </div>
            </div>

            <form method="get" asp-controller="Takip" asp-action="Index" class="row align-items-end g-2">
                <div class="col-md-5">
                    <label for="taskSearch" class="form-label">Ara (server-side)</label>
                    <input id="taskSearch" name="q" value="@q" type="text" class="form-control"
                           placeholder="Konu / Açan / Takip Eden / Durum..." autocomplete="off" />
                </div>

                <div class="col-md-3">
                    <label for="kisiFilter" class="form-label">Kişi</label>
                    <select id="kisiFilter" name="kisi" class="form-select">
                        <option value="">Tümü</option>
                        @foreach (var kisi in kisiList)
                        {
                            <option value="@kisi" selected="@(string.Equals(kisi, selectedKisi, StringComparison.OrdinalIgnoreCase))">@kisi</option>
                        }
                    </select>
                </div>

                <div class="col-md-4 d-flex justify-content-md-end gap-2 flex-wrap">
                    <input type="hidden" name="page" value="1" />
                    <input type="hidden" name="pageSize" value="@pageSize" />

                    <div class="d-flex flex-column align-items-md-end">
                        <label for="boardStatusFilter" class="form-label mb-1">Kolon Filtre</label>
                        <select id="boardStatusFilter" class="form-select form-select-sm responsive-select">
                            <option value="all" selected>Tümü</option>
                            <option value="Beklemede">Beklemede</option>
                            <option value="Aktif">Aktif</option>
                            <option value="Döküman İletildi">Döküman İletildi</option>
                            <option value="Tamamlandı">Tamamlandı</option>

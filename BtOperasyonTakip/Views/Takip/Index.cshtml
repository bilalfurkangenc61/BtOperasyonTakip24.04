@model BtOperasyonTakip.Models.JiraBoardViewModel
@{
    ViewData["Title"] = "İş Takip";

    var durumListesi = (ViewBag.DurumListesi as List<string>) ?? new List<string>();
    var anaDurumlar = ((IEnumerable<string>?)ViewBag.AnaDurumlar ?? new[] { "Aktif", "Beklemede", "Tamamlandı" }).ToList();
    var selectedEkstraDurumlar = ((IEnumerable<string>?)ViewBag.SelectedEkstraDurumlar ?? Enumerable.Empty<string>()).ToList();
    var pagedTasks = (ViewBag.PagedTasks as List<BtOperasyonTakip.Models.JiraTask>) ?? new List<BtOperasyonTakip.Models.JiraTask>();
    var durumTaskMap = durumListesi.ToDictionary(
        durum => durum,
        durum => pagedTasks.Where(t => string.Equals((t.Durum ?? "").Trim(), durum, StringComparison.OrdinalIgnoreCase)).ToList(),
        StringComparer.OrdinalIgnoreCase);

    var siraliDurumListesi = anaDurumlar
        .Concat(durumListesi.Where(d => !anaDurumlar.Contains(d, StringComparer.OrdinalIgnoreCase)))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();
    var ekstraDurumlar = siraliDurumListesi
        .Where(d => !anaDurumlar.Contains(d, StringComparer.OrdinalIgnoreCase))
        .ToList();

    var beklemedeCount = durumTaskMap.TryGetValue("Beklemede", out var beklemedeTasks) ? beklemedeTasks.Count : 0;
    var aktifCount = durumTaskMap.TryGetValue("Aktif", out var aktifTasks) ? aktifTasks.Count : 0;
    var tamamlandiCount = durumTaskMap.TryGetValue("Tamamlandı", out var tamamlandiTasks) ? tamamlandiTasks.Count : 0;
    var totalCount = durumTaskMap.Sum(x => x.Value.Count);

    var gorunenKolonlar = anaDurumlar
        .Concat(selectedEkstraDurumlar)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();

    var ekstraDurumSecenekleri = siraliDurumListesi
        .Where(d => !anaDurumlar.Contains(d, StringComparer.OrdinalIgnoreCase))
        .ToList();

    var talepAcanList = Model?.TalepAcanSecenekleri ?? new List<string>();
    var takipEdenList = Model?.TakipEdenSecenekleri ?? new List<string>();
    var kisiList = (ViewBag.KisiSecenekleri as List<string>) ?? new List<string>();
    var selectedKisi = (ViewBag.SelectedKisi as string) ?? "";
    var selectedAy = (ViewBag.SelectedAy as string) ?? DateTime.Now.ToString("yyyy-MM");
    var selectedAyLabel = (ViewBag.SelectedAyLabel as string) ?? DateTime.Now.ToString("MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"));
    var availableAylar = (ViewBag.AvailableAylar as IEnumerable<DateTime> ?? Enumerable.Empty<DateTime>()).ToList();
    var taskLatestDetaylar = (ViewBag.TaskLatestDetaylar as IDictionary<int, BtOperasyonTakip.Models.Detay?>) ?? new Dictionary<int, BtOperasyonTakip.Models.Detay?>();
    var taskMusteriDurumlari = (ViewBag.TaskMusteriDurumlari as IDictionary<int, string>) ?? new Dictionary<int, string>();

    var q = Model?.Q ?? "";
    var currentPage = Model?.Page ?? 1;
    var pageSize = Model?.PageSize ?? 10;
    var totalPages = Model?.TotalPages ?? 1;
    var totalDbCount = Model?.TotalCount ?? 0;

    static string GetStatusSubtitle(string durum) => durum switch
    {
        "Beklemede" => "Aksiyon bekleyen kayıtlar",
        "Aktif" => "Çalışılan işler",
        "Tamamlandı" => "Sonuçlanan işler",
        _ => "Bu duruma ait kayıtlar"
    };

    static (string Accent, string Soft, string Border, string Text) GetStatusPalette(string durum)
    {
        return durum switch
        {
            "Beklemede" => ("#f59e0b", "#fff7d6", "#ffe28a", "#8f5b00"),
            "Aktif" => ("#2563eb", "#dbeafe", "#bfdbfe", "#1d4ed8"),
            "Tamamlandı" => ("#22c55e", "#e3fcef", "#abf5d1", "#006644"),
            _ => GetDynamicStatusPalette(durum)
        };
    }

    static (string Accent, string Soft, string Border, string Text) GetDynamicStatusPalette(string durum)
    {
        unchecked
        {
            var hash = 17;
            foreach (var ch in durum ?? string.Empty)
            {
                hash = (hash * 31) + ch;
            }

            var hue = Math.Abs(hash % 360);
            return (
                $"hsl({hue} 62% 48%)",
                $"hsl({hue} 85% 96%)",
                $"hsl({hue} 70% 84%)",
                $"hsl({hue} 68% 34%)");
        }
    }
}


            grid-template-columns: 1fr;
            gap: 0.2rem;
        }

        .takip-toolbar {
            flex-direction: column;
            align-items: flex-start;
        }

        .takip-column-toggle-bar {
            align-items: flex-start;
        }
    }

</style>

<div class="container py-2 takip-shell">
    <div class="takip-hero mb-4 d-flex flex-column gap-4">
        <div class="d-flex flex-column flex-xl-row align-items-xl-center justify-content-between gap-3">
            <div>
                <div class="takip-hero-eyebrow" data-i18n="Operasyon · İş Takip">Operasyon · İş Takip</div>
                <div class="takip-hero-title" data-i18n="İş akışını daha hızlı yönetin">İş akışını daha hızlı yönetin</div>
                <div class="takip-hero-subtext" data-i18n="Kişi bazlı görünüm, hızlı filtreleme, görev durumu güncelleme ve detay takibini tek ekranda yönetin.">
                    Kişi bazlı görünüm, hızlı filtreleme, görev durumu güncelleme ve detay takibini tek ekranda yönetin.
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="takip-chip"><span data-i18n="Görünüm:">Görünüm:</span> @(string.IsNullOrWhiteSpace(selectedKisi) ? "Tüm Kişiler" : selectedKisi)</span>
                <span class="takip-chip"><span data-i18n="Ay:">Ay:</span> @selectedAyLabel</span>
                <span class="takip-chip"><span data-i18n="Toplam:">Toplam:</span> @totalDbCount</span>

                <a class="btn btn-sm btn-light fw-semibold"
                   href="@Url.Action("ExportExcelGrouped", "Takip")">
                    <span data-i18n="Excel (JiraId Gruplu)">Excel (JiraId Gruplu)</span>
                </a>
                <a class="btn btn-sm btn-outline-light fw-semibold"
                   href="@Url.Action("ExportExcelTumAylar", "Takip")">
                    <span data-i18n="Excel (Tüm Aylar)">Excel (Tüm Aylar)</span>
                </a>

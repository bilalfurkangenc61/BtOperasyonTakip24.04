@{
    Layout = null;
    ViewData["Title"] = "Kayıt Ol";
}

<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        margin: 0;
        min-height: 100vh;
        background: #f8f9fa;
        font-family: 'Segoe UI', sans-serif;
    }

    .register-shell {
        min-height: 100vh;
        padding: 1rem;
    }

    .register-card {
        width: min(100%, 400px);
    }

    @@media (max-width: 576px) {
        .register-card {
            padding: 1.25rem !important;
        }
    }
</style>
</head>
<body>

<div class="register-shell d-flex align-items-center justify-content-center">
    <div class="card shadow p-4 register-card">
        <h3 class="text-center text-primary fw-bold mb-3">📝 Yeni Hesap Oluştur</h3>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        else if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form method="post">
            <div class="mb-3">
                <label>Kullanıcı Adı</label>
                <input name="username" class="form-control" required />
            </div>
            <div class="mb-3">
                <label>E-posta</label>
                <input name="email" class="form-control" type="email" />
            </div>
            <div class="mb-3">
                <label>Şifre</label>
                <input name="password" class="form-control" type="password" required />
            </div>
            <div class="form-group">
                <label for="Role">Kullanıcı Tipi</label>
                <select name="Role" class="form-control" id="Role">
                    <option value="Saha" selected>Saha</option>
                    <option value="Operasyon">Operasyon (Operasyon Personeli)</option>
                    <option value="Uyum">Uyum</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary w-100">Kaydol</button>
        </form>

        <div class="mt-3 text-center">
            <a asp-action="Login">Zaten hesabın var mı? Giriş yap</a>
        </div>
    </div>
</div>
</body>
</html>

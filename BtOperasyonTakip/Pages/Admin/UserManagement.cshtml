@page
@model BtOperasyonTakip.Pages.Admin.UserManagementModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<h2 class="text-primary" data-i18n="Kullanıcı Yönetimi">Kullanıcı Yönetimi</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
else if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-bordered">
    <thead>
        <tr>
            <th data-i18n="Kullanıcı Adı">Kullanıcı Adı</th>
            <th data-i18n="E-posta">E-posta</th>
            <th data-i18n="İşlemler">İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id">
                        <button type="submit" class="btn btn-danger btn-sm" data-i18n="Sil">Sil</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>